  <style>
    .snippet-box { padding: 28px; border-radius: var(--avab-radius-sm); background: var(--avab-white); border: 1px solid var(--avab-border); border-left: 8px solid var(--avab-green); box-shadow: var(--avab-shadow-sm); height: 100%; }
    .snippet-box .q { display: block; margin-bottom: 8px; font-size: 0.8rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; color: var(--avab-green); }
    .snippet-box h3 { font-size: 1.25rem; margin-bottom: 10px; }
    .snippet-box p:last-child { margin-bottom: 0; }

    .section--dark { background: var(--avab-dark); color: #fff; border-bottom: none; }
    .section--dark h2, .section--dark h3, .section--dark strong { color: #fff; }
    .section--dark p { color: rgba(255, 255, 255, 0.82); }
    .section--dark .lead-dark { color: rgba(255, 255, 255, 0.9); }

    .fact-strip { display: grid; grid-template-columns: repeat(5, minmax(0, 1fr)); gap: 0; border: 1px solid var(--avab-border); border-radius: var(--avab-radius-sm); overflow: hidden; box-shadow: var(--avab-shadow-sm); background: var(--avab-white); }
    .fact-strip .fact { padding: 22px 24px; }
    .fact-strip .fact + .fact { border-left: 1px solid var(--avab-border); }
    .fact-strip .fact span { display: block; margin-bottom: 6px; color: var(--avab-dark-muted); font-size: 0.74rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em; }
    .fact-strip .fact strong { display: block; color: var(--avab-dark); font-size: 1.02rem; line-height: 1.35; }

    .mini-grid { display: grid; gap: 16px; margin-top: 24px; }
    .mini-grid.cols-2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .mini-grid.cols-3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    .mini-card { padding: 24px; border: 1px solid var(--avab-border); border-radius: var(--avab-radius-sm); background: var(--avab-white); box-shadow: var(--avab-shadow-sm); }
    .mini-card b { display: block; margin-bottom: 8px; font-size: 1.05rem; color: var(--avab-dark); }
    .mini-card p { margin: 0; font-size: 0.96rem; }

    .stat-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 16px; margin-top: 36px; }
    .stat { padding: 26px 22px; border: 1px solid rgba(255, 255, 255, 0.16); border-radius: var(--avab-radius-sm); background: rgba(255, 255, 255, 0.05); }
    .stat strong { display: block; margin-bottom: 8px; color: var(--avab-green); font-size: clamp(1.7rem, 3vw, 2.4rem); line-height: 1; }
    .stat span { color: rgba(255, 255, 255, 0.78); font-size: 0.94rem; }
    .calc-note { margin-top: 18px; color: rgba(255, 255, 255, 0.62); font-size: 0.86rem; }

    .zone-table-wrap { width: 100%; overflow-x: auto; margin-top: 28px; border-radius: var(--avab-radius-sm); border: 1px solid var(--avab-border); box-shadow: var(--avab-shadow-sm); }
    .zone-table { width: 100%; min-width: 520px; border-collapse: collapse; background: var(--avab-white); }
    .zone-table th, .zone-table td { padding: 16px 20px; border-bottom: 1px solid var(--avab-border); text-align: left; vertical-align: top; }
    .zone-table th { background: var(--avab-light); font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.03em; font-weight: 800; }
    .zone-table td:first-child { width: 30%; font-weight: 800; color: var(--avab-dark); }
    .zone-table tr:last-child td { border-bottom: none; }

    .gallery { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 18px; margin-top: 32px; }
    .gallery figure { margin: 0; }
    .gallery .wide { grid-column: 1 / -1; }
    .media-placeholder { min-height: 320px; display: grid; place-items: center; padding: 28px; border: 2px dashed rgba(40, 46, 42, 0.22); border-radius: var(--avab-radius-sm); background: linear-gradient(135deg, #f7f8f7 0%, #e9eae9 100%); color: var(--avab-dark-muted); text-align: center; }
    .media-placeholder strong { display: block; margin-bottom: 6px; color: var(--avab-dark); }
    .section--dark .media-placeholder { border-color: rgba(255, 255, 255, 0.3); background: rgba(255, 255, 255, 0.05); color: rgba(255, 255, 255, 0.7); }
    .section--dark .media-placeholder strong { color: #fff; }
    figure figcaption { padding-top: 12px; color: var(--avab-dark-muted); font-size: 0.9rem; }
    .section--dark figcaption { color: rgba(255, 255, 255, 0.64); }

    .lesson-grid { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 16px; margin-top: 32px; }
    .lesson { padding: 26px; border: 1px solid var(--avab-border); border-radius: var(--avab-radius-sm); background: var(--avab-white); box-shadow: var(--avab-shadow-sm); }
    .lesson .num { display: block; margin-bottom: 18px; color: var(--avab-green); font-size: 0.78rem; font-weight: 900; letter-spacing: 0.04em; }
    .lesson h3 { font-size: 1.12rem; margin-bottom: 8px; }
    .lesson p { margin: 0; font-size: 0.95rem; }

    .quote { margin: 0; padding: 48px; border-left: 8px solid var(--avab-green); border-radius: var(--avab-radius); background: var(--avab-white); box-shadow: var(--avab-shadow-lg); }
    .quote p { color: var(--avab-dark); font-size: clamp(1.15rem, 2.2vw, 1.5rem); line-height: 1.55; }
    .quote footer { margin-top: 24px; color: var(--avab-dark-muted); }
    .quote footer strong { display: block; color: var(--avab-dark); }

    .related { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 28px; }
    .related a { padding: 10px 16px; border: 1px solid rgba(255, 255, 255, 0.28); border-radius: 999px; color: #fff; font-size: 0.9rem; font-weight: 700; transition: var(--transition-smooth); }
    .related a:hover { background: var(--avab-green); border-color: var(--avab-green); color: var(--avab-dark); }

    @media (max-width: 1024px) {
      .fact-strip { grid-template-columns: repeat(2, 1fr); }
      .fact-strip .fact:nth-child(odd) { border-left: none; }
      .fact-strip .fact { border-top: 1px solid var(--avab-border); }
      .fact-strip .fact:nth-child(1), .fact-strip .fact:nth-child(2) { border-top: none; }
      .mini-grid.cols-3, .lesson-grid { grid-template-columns: repeat(2, 1fr); }
    }
    @media (max-width: 768px) {
      .fact-strip, .mini-grid.cols-2, .mini-grid.cols-3, .gallery, .lesson-grid { grid-template-columns: 1fr; }
      .fact-strip .fact { border-left: none; }
      .stat-grid { grid-template-columns: 1fr; }
      .quote { padding: 32px 24px; }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
        <li><a href="https://avab.eu/">Start</a></li>
        <li><a href="https://avab.eu/referenser/">Referenser</a></li>
