    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad levererade AVAB till Minnebergsskolan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AVAB levererade AV-tekniken i hela skolan: interaktiva Epson-projektorer, högtalare och inkopplingspaneler i klassrum och lärarrum, 20 hörsalar, 18 infoskärmar, hörslingor och komplett ljud-, bild- och styrteknik i matsal och aula."
        }
      },
      {
        "@type": "Question",
        "name": "Hur är klassrummen på Minnebergsskolan utrustade?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Klassrummen har Epson touchprojektor, högtalare och panel med HDMI samt ljud in och ut. Musik kan spelas utan att projektorn startas och hörslingesändare kan anslutas vid behov."
        }
      },
      {
        "@type": "Question",
        "name": "Var finns hörslingor på Minnebergsskolan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Hörslingor projekterades för biblioteket, matsalens nedre och övre plan samt gradängen och aulan. Klassrummen har även anslutningsmöjlighet för hörslingesändare."
        }
      },
      {
        "@type": "Question",
        "name": "Vilken teknik finns i Minnebergsskolans aula?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Aulan har sex meter bred projektorduk, Epson-projektor, Turbosound line-array, Crestronstyrning, DMX-ljus, fyra trådlösa Sennheiser-system, Dante och möjlighet att ansluta flyttbara basar."
        }
      },
      {
        "@type": "Question",
        "name": "Hur många informationsskärmar finns i skolan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AVAB installerade 18 stycken 55-tums informationsskärmar runt om i Minnebergsskolan."
        }
      },
      {
        "@type": "Question",
        "name": "Varför används Dante i aulan?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dante transporterar digitalt ljud över skolans nätverk. Mixern och flyttbara basar kan anslutas i förberedda nätverksuttag och placeras där lokalen och evenemanget kräver."
        }
      }
    ]
  }
  </script>

