  <!-- Delad designsystem-CSS -->
  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- AEO-svarsruta (snippet-box) – samma som övriga tjänstesidor ---- */
    .snippet-box {
      padding: 24px 28px;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 8px solid var(--avab-green);
      box-shadow: var(--avab-shadow-sm);
      margin-top: 28px;
    }
    .snippet-box strong { display: flex; align-items: center; gap: 8px; font-size: 1.1rem; margin-bottom: 8px; color: var(--avab-dark); }
    .snippet-box strong::before { content: "⚡"; font-size: 1.05rem; }
    .snippet-box p { margin-bottom: 0; font-size: 1.05rem; }

    /* ---- Fördelar (kortlista) ---- */
    .summary-list { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 16px; list-style: none; margin: 0; }
    .summary-list li { padding: 24px; border-radius: var(--avab-radius-sm); background: var(--avab-white); border: 1px solid var(--avab-border); box-shadow: var(--avab-shadow-sm); font-size: 1rem; color: var(--avab-dark-muted); line-height: 1.55; }
    .summary-list strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.12rem; }

    /* ---- Lösningskort med hover/fokus-expandering ---- */
    .solutions-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 24px; }
    .solution-card { padding: 36px; border-radius: var(--avab-radius); background: var(--avab-white); border: 1px solid var(--avab-border); box-shadow: var(--avab-shadow-sm); transition: var(--transition-smooth); display: flex; flex-direction: column; height: 100%; }
    .solution-card:hover, .solution-card:focus-within { transform: translateY(-8px); box-shadow: var(--avab-shadow-lg); border-color: var(--avab-green); }
    .solution-card h3 { font-size: 1.3rem; margin-bottom: 10px; }
    .solution-card > p { color: var(--avab-dark-muted); margin-bottom: 0; }
    .hover-indicator { margin-top: auto; padding-top: 22px; font-weight: 800; font-size: 0.8rem; text-transform: uppercase; letter-spacing: 0.05em; color: var(--avab-green); transition: var(--transition-smooth); }
    .solution-card:hover .hover-indicator, .solution-card:focus-within .hover-indicator { opacity: 0; height: 0; padding-top: 0; overflow: hidden; }
    .solution-expandable { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.4s cubic-bezier(0.25, 1, 0.5, 1); }
    .solution-expand-inner { overflow: hidden; opacity: 0; transition: opacity 0.3s ease; }
    .solution-card:hover .solution-expandable, .solution-card:focus-within .solution-expandable { grid-template-rows: 1fr; }
    .solution-card:hover .solution-expand-inner, .solution-card:focus-within .solution-expand-inner { opacity: 1; margin-top: 12px; }
    .solution-card .bullet-list { margin-top: 0; }
    .solution-card .bullet-list li { font-size: 0.96rem; font-weight: 500; }

    /* ---- Praktik-/exempelruta ---- */
    .practical-box { background: var(--avab-white); padding: 36px; border-radius: var(--avab-radius); border: 1px solid var(--avab-border); box-shadow: var(--avab-shadow-sm); }
    .practical-box h3 { color: var(--avab-green); }
    .practical-box h3:not(:first-child) { margin-top: 32px; }
    .practical-box p:last-child { margin-bottom: 0; }

    /* ---- Varningsruta (utrymning/inrymning) ---- */
    .warning-box { background: rgba(204, 0, 0, 0.05); border-left: 6px solid #cc0000; padding: 24px 28px; border-radius: 0 var(--avab-radius-sm) var(--avab-radius-sm) 0; box-shadow: var(--avab-shadow-sm); }
    .warning-box strong { color: #cc0000; display: block; margin-bottom: 8px; font-size: 1.12rem; }
    .warning-box p { margin-bottom: 0; }

    /* ---- Prisindikator – samma som övriga tjänstesidor ---- */
    .price-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 8px; }
    .price-card { background: var(--avab-white); border: 1px solid var(--avab-border); border-radius: var(--avab-radius); padding: 36px 32px; box-shadow: var(--avab-shadow-sm); text-align: center; display: flex; flex-direction: column; min-height: 300px; }
    .price-card.featured { border: 2px solid var(--avab-green); box-shadow: var(--avab-shadow-lg); position: relative; }
    .price-card.featured::before { content: "Mest vald"; position: absolute; top: -14px; left: 50%; transform: translateX(-50%); background: var(--avab-green); color: var(--avab-dark); font-weight: 800; font-size: 0.78rem; text-transform: uppercase; letter-spacing: 0.04em; padding: 4px 16px; border-radius: 999px; }
    .price-label { display: inline-flex; align-self: center; padding: 8px 18px; border-radius: 999px; background: var(--avab-light); border: 1px solid var(--avab-border); color: var(--avab-dark); font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 24px; }
    .price-card .price { font-size: clamp(2.1rem, 4vw, 2.8rem); line-height: 1; color: var(--avab-green); font-weight: 800; margin-bottom: 20px; }
    .price-card p { font-size: 1.02rem; margin-bottom: 0; }

    /* ---- Interna länkpiller ---- */
    .link-pills { display: flex; flex-wrap: wrap; gap: 14px; margin-top: 8px; }
    .link-pills a { display: inline-flex; align-items: center; background: var(--avab-white); color: var(--avab-dark); border: 1px solid var(--avab-border); font-weight: 700; padding: 12px 22px; border-radius: 999px; font-size: 0.98rem; transition: var(--transition-smooth); box-shadow: var(--avab-shadow-sm); }
    .link-pills a:hover { background: var(--avab-green); border-color: var(--avab-green); transform: translateY(-2px); }

    /* ---- Bildplatshållare (för referenser utan riktig projektbild ännu) ---- */
    .image-placeholder { min-height: 210px; width: 100%; border-bottom: 1px solid var(--avab-border); border-radius: 0; background: linear-gradient(135deg, #f7f8f7 0%, #e9eae9 100%); display: flex; align-items: center; justify-content: center; text-align: center; padding: 24px; color: var(--avab-dark-muted); font-weight: 800; }
    .image-placeholder span { display: block; max-width: 32ch; }

    @media (max-width: 1024px) { .price-grid { grid-template-columns: 1fr; } }
    @media (max-width: 768px) {
      /* På mobil: visa lösningskortens innehåll direkt (inget hover) */
      .solution-expandable { grid-template-rows: 1fr; }
      .solution-expand-inner { opacity: 1; }
      .hover-indicator { display: none; }
    }
  </style>
</head>
