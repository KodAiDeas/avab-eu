  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "@id": "https://www.avab.eu/rastsignal/#faq",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad är ett rastsignalsystem?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ett rastsignalsystem är ett schemastyrt ljudsystem för skolklockor, rastsignaler och talmeddelanden. Det används för att skapa tydliga tider och gemensam information i skolmiljö."
        }
      },
      {
        "@type": "Question",
        "name": "Kan vi använda befintliga högtalare?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, om högtalare och kablage fungerar kan de ofta återanvändas. Då uppgraderar vi styrning, centralenhet och schemahantering."
        }
      },
      {
        "@type": "Question",
        "name": "Kan olika delar av skolan få olika signaler?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Systemet kan delas in i zoner, till exempel lågstadium, mellanstadium, skolgård, sporthall eller separata byggnader."
        }
      },
      {
        "@type": "Question",
        "name": "Kan systemet spela upp talmeddelanden?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Det kan användas för talade meddelanden, egna ljudfiler och förprogrammerade signaler, beroende på vald lösning och behörigheter."
        }
      },
      {
        "@type": "Question",
        "name": "Är rastsignal samma sak som utrymningslarm?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Nej. Rastsignal är ett informationssystem och ska inte ersätta certifierat brandlarm, talat utrymningslarm eller inrymningslarm."
        }
      },
      {
        "@type": "Question",
        "name": "Vad behöver ni för att lämna förslag?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Vi behöver veta skolans storlek, befintlig teknik, önskade zoner, om utomhusytor ska täckas och hur systemet ska administreras i vardagen."
        }
      }
    ]
  }
  </script>

