---
import SiteHeader from "../../../components/SiteHeader.astro";

import "../../../styles/avab.css";



export const prerender = true;

interface Props {
  title?: string;
}

const { title = "Köpcentrum & galleria | Ljud, signage, LED & kameraövervakning | AVAB" } = Astro.props;
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Köpcentrum &amp; galleria | Ljud, signage, LED &amp; kameraövervakning | AVAB</title>
  <meta name="description" content="AVAB bygger teknik för köpcentrum och gallerior: zonljud, Digital Signage, totems, LED-väggar, kameraövervakning, garage, PA, tross och service." />
  <meta name="robots" content="index, follow, max-image-preview:large" />
  <meta name="author" content="AVAB" />
  <meta name="theme-color" content="#282E29" />
  <link rel="canonical" href="https://www.avab.eu/kopcentrum-och-galleria/" />

  <meta property="og:title" content="Köpcentrum & galleria | Ljud, signage, LED & kameraövervakning | AVAB" />
  <meta property="og:description" content="Kompletta tekniklösningar för gallerior och köpcentrum: bakgrundsljud i zoner, infoskärmar, totems, LED-väggar, kameraövervakning, garage, PA och tross för torg och event." />
  <meta property="og:image" content="https://images.unsplash.com/photo-1519567281027-6152604e2599?auto=format&fit=crop&q=80&w=1600" />
  <meta property="og:image:width" content="1600" />
  <meta property="og:image:height" content="1067" />
  <meta property="og:image:alt" content="Galleria med gångstråk, ljus och publika ytor – teknik från AVAB" />
  <meta property="og:url" content="https://www.avab.eu/kopcentrum-och-galleria/" />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="sv_SE" />
  <meta property="og:site_name" content="AVAB" />

  <!-- Twitter / X Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content="Köpcentrum & galleria | Ljud, signage, LED & kameraövervakning | AVAB" />
  <meta name="twitter:description" content="Bakgrundsljud i zoner, Digital Signage, LED-väggar, kameraövervakning, garage, PA och tross för köpcentrum och gallerior." />
  <meta name="twitter:image" content="https://images.unsplash.com/photo-1519567281027-6152604e2599?auto=format&fit=crop&q=80&w=1600" />
  <meta name="twitter:image:alt" content="Galleria med gångstråk, ljus och publika ytor – teknik från AVAB" />

  <!-- Favicon (byt sökväg till AVAB:s riktiga ikonfiler) -->
  <link rel="icon" href="/favicon.ico" sizes="any" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Service",
    "name": "Teknik för köpcentrum och galleria",
    "url": "https://www.avab.eu/kopcentrum-och-galleria/",
    "provider": {
      "@type": "LocalBusiness",
      "name": "AVAB",
      "url": "https://www.avab.eu/",
      "logo": "https://avab.eu/wp-content/uploads/logo.png",
      "telephone": "+46-54-820280",
      "email": "info@avab.eu",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Skraggevägen 4",
        "postalCode": "663 41",
        "addressLocality": "Hammarö",
        "addressRegion": "Värmland",
        "addressCountry": "SE"
      }
    },
    "areaServed": "Sverige",
    "serviceType": [
      "AV-teknik köpcentrum",
      "AV-teknik galleria",
      "Bakgrundsljud köpcentrum",
      "Zonstyrt ljud galleria",
      "Digital Signage köpcentrum",
      "Infoskärmar och totems",
      "LED-väggar",
      "Kameraövervakning köpcentrum",
      "Kameraövervakning garage",
      "Certifiering och funktionskontroll",
      "PA-system torg",
      "Tross och scenteknik",
      "Systemintegration",
      "Service och dokumentation"
    ],
    "description": "AVAB projekterar, installerar, certifierar, driftsätter och dokumenterar teknik för köpcentrum, gallerior, handelsplatser och parkeringsmiljöer. Lösningarna omfattar zonstyrt bakgrundsljud, Digital Signage, väggmonterade skärmar, totems, LED-väggar, kameraövervakning, garage, PA, tross, styrning, serviceavtal och tekniskt underlag för upphandling."
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad behöver ett köpcentrum för teknik?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ett köpcentrum behöver ofta zonstyrt bakgrundsljud, tydliga utrop, Digital Signage, väggmonterade skärmar, totems, LED-väggar, kameraövervakning, teknik för garage och parkering, samt PA och tross för torg, kampanjer och mindre scener."
        }
      },
      {
        "@type": "Question",
        "name": "Kan AVAB projektera kameraövervakning för hela gallerian?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB projekterar, installerar, certifierar, driftsätter och dokumenterar kameraövervakningslösningar för hela fastigheten, inklusive entréer, gångstråk, torg, butiksnära ytor, lastzoner, teknikytor och garage."
        }
      },
      {
        "@type": "Question",
        "name": "Hur fungerar bakgrundsljud i olika zoner?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Bakgrundsljud delas upp i zoner, till exempel entréer, gångstråk, food court, torg, toaletter och garage. Varje zon kan ha egen volym, ljudkaraktär och styrning så att ljudet upplevs behagligt utan att störa butikerna."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är skillnaden mellan Digital Signage, totems och LED-väggar?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Digital Signage är nätverk av skärmar för information, reklam och vägvisning. Totems är fristående skärmar som ofta används vid entréer och knutpunkter. LED-väggar används när man behöver större bildytor, starkare visuellt uttryck eller synlighet på längre avstånd."
        }
      },
      {
        "@type": "Question",
        "name": "Kan samma teknik användas för kampanjer och event på ett torg?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Ett köpcentrum kan förberedas med fasta anslutningar, PA, trosspunkter, styrning och bildytor så att torg, kampanjytor och mindre scener snabbt kan användas för event, invigningar och butikskampanjer."
        }
      },
      {
        "@type": "Question",
        "name": "Kan ni även hjälpa till med garage och parkering?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB kan projektera teknik för garage och parkeringsmiljöer med kameraövervakning, infoskärmar, trygghetspunkter, ljud, utrop och lösningar som gör det lättare att skapa överblick och tryggare flöden."
        }
      },
      {
        "@type": "Question",
        "name": "När bör AV-tekniken komma in i ett köpcentrumsprojekt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AV-tekniken bör komma in tidigt, innan kabelvägar, nätverk, teknikrum, montagepunkter, infästningar och budget är låsta. Det minskar risken för dyra kompletteringar och gör upphandlingen tydligare."
        }
      },
      {
        "@type": "Question",
        "name": "Kan AVAB leverera serviceavtal efter installation?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB erbjuder service, dokumentation, funktionskontroller, support och möjlighet till löpande utveckling när butiker, flöden, skyltning och säkerhetsbehov förändras."
        }
      }
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Start", "item": "https://www.avab.eu/" },
      { "@type": "ListItem", "position": 2, "name": "Miljöer", "item": "https://www.avab.eu/#miljoer" },
      { "@type": "ListItem", "position": 3, "name": "Köpcentrum & galleria", "item": "https://www.avab.eu/kopcentrum-och-galleria/" }
    ]
  }
  </script>

  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://www.avab.eu/kopcentrum-och-galleria/#webpage",
    "url": "https://www.avab.eu/kopcentrum-och-galleria/",
    "name": "Köpcentrum & galleria | Ljud, signage, LED & kameraövervakning | AVAB",
    "description": "Teknik för köpcentrum och gallerior: zonstyrt bakgrundsljud, Digital Signage, totems, LED-väggar, kameraövervakning, garage, PA, tross, styrning, service och dokumentation.",
    "inLanguage": "sv-SE",
    "isPartOf": { "@type": "WebSite", "name": "AVAB", "url": "https://www.avab.eu/" },
    "datePublished": "2025-01-01",
    "dateModified": "2026-06-18",
    "speakable": {
      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".lead", ".compact-faq"]
    }
  }
  </script>

  <link rel="preconnect" href="https://images.unsplash.com" crossorigin>
  <link rel="preconnect" href="https://avab.eu" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Preload av hero-bilden (LCP) -->
  <link rel="preload" as="image" fetchpriority="high"
    href="https://images.unsplash.com/photo-1519567281027-6152604e2599?auto=format&fit=crop&q=80&w=1800">

  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Delad designsystem-CSS -->
  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- Kort-svar-box (AEO featured snippet) ---- */
    .snippet-box {
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 8px solid var(--avab-green);
      border-radius: var(--avab-radius);
      padding: 36px;
      box-shadow: var(--avab-shadow-sm);
      height: 100%;
    }
    .snippet-box h2 { font-size: 1.55rem; margin-bottom: 14px; }
    .snippet-box p { margin-bottom: 0; }

    /* ---- Sammanfattningslista (fet ingress per punkt) ---- */
    .summary-list { list-style: none; display: grid; gap: 16px; margin: 0; }
    .summary-list li {
      position: relative;
      padding-left: 32px;
      color: var(--avab-dark-muted);
      font-size: 1.02rem;
      line-height: 1.6;
    }
    .summary-list li::before {
      content: "→";
      position: absolute;
      left: 0;
      top: 0;
      color: var(--avab-green);
      font-size: 1.15rem;
      font-weight: 800;
    }
    .summary-list li strong { display: block; color: var(--avab-dark); font-weight: 800; }

    /* ---- Leveransområden (numrerade kort) ---- */
    .feature-card {
      position: relative;
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      padding: 30px;
      box-shadow: var(--avab-shadow-sm);
      overflow: hidden;
      transition: var(--transition-smooth);
      height: 100%;
    }
    .feature-card:hover {
      transform: translateY(-4px);
      border-color: rgba(143, 192, 37, 0.42);
      box-shadow: var(--avab-shadow-lg);
    }
    .feature-card .number {
      position: absolute;
      top: 16px;
      right: 22px;
      font-size: 2.4rem;
      font-weight: 800;
      color: rgba(143, 192, 37, 0.32);
      line-height: 1;
      letter-spacing: -0.02em;
    }
    .feature-card h3 { font-size: 1.2rem; margin-bottom: 10px; max-width: 82%; }
    .feature-card p { font-size: 0.98rem; color: var(--avab-dark-muted); margin-bottom: 0; }

    /* ---- Processteg (numrerad badge, dark-on-green = bra kontrast) ---- */
    .process-card {
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius-sm);
      padding: 26px;
      box-shadow: var(--avab-shadow-sm);
      height: 100%;
    }
    .process-card strong {
      display: flex;
      align-items: center;
      gap: 10px;
      font-size: 1rem;
      font-weight: 800;
      color: var(--avab-dark);
      margin-bottom: 12px;
    }
    .process-card strong em {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 34px;
      height: 34px;
      border-radius: 999px;
      background: var(--avab-green);
      color: var(--avab-dark);
      font-style: normal;
      font-size: 0.95rem;
      font-weight: 800;
      flex: 0 0 auto;
    }
    .process-card h3 { font-size: 1.2rem; margin-bottom: 10px; }
    .process-card p { font-size: 0.96rem; color: var(--avab-dark-muted); margin-bottom: 0; }

    /* ---- Lösningskort (bild + etikett + innehåll) ---- */
    .solution-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(440px, 1fr));
      gap: 24px;
    }
    .solution-card {
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-radius: var(--avab-radius);
      box-shadow: var(--avab-shadow-sm);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      height: 100%;
      transition: var(--transition-smooth);
    }
    .solution-card:hover {
      transform: translateY(-6px);
      box-shadow: var(--avab-shadow-lg);
      border-color: rgba(143, 192, 37, 0.42);
    }
    .solution-image { position: relative; }
    .solution-image img { width: 100%; height: 220px; object-fit: cover; display: block; }
    .image-label {
      position: absolute;
      left: 16px;
      bottom: 16px;
      padding: 8px 14px;
      border-radius: 999px;
      background: rgba(255, 255, 255, 0.94);
      color: var(--avab-dark);
      font-size: 0.82rem;
      font-weight: 800;
      box-shadow: var(--avab-shadow-sm);
    }
    .solution-content { padding: 30px; display: flex; flex-direction: column; flex-grow: 1; }
    .solution-content h3 { font-size: 1.3rem; }
    .solution-content > p { color: var(--avab-dark-muted); }

    /* ---- Referenstaggar ---- */
    .tag-list { display: flex; flex-wrap: wrap; gap: 8px; margin-top: auto; padding-top: 6px; }
    .tag {
      display: inline-flex;
      padding: 5px 12px;
      border-radius: 999px;
      background: var(--avab-green-soft);
      color: var(--avab-dark);
      font-size: 0.78rem;
      font-weight: 800;
    }

    /* ---- FAQ: vänsterställd rubrik + tvåkolumnslayout (som simhall) ---- */
    .compact-faq {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 0;
      max-width: 1060px;
      margin: 0 auto;
    }
    .compact-faq details.faq-item { padding: 20px 0; }
    .compact-faq summary { font-size: 1.05rem; }
    .compact-faq details.faq-item p { font-size: 0.98rem; }
    .compact-faq details.faq-item:nth-child(1),
    .compact-faq details.faq-item:nth-child(2) { border-top: 1px solid var(--avab-border); }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 768px) {
      .solution-grid { grid-template-columns: 1fr; }
      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
      .feature-card .number { font-size: 2rem; }
      .snippet-box { padding: 28px; }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
        <li><a href="https://www.avab.eu/">Start</a></li>
        <li><a href="https://www.avab.eu/#miljoer">Miljöer</a></li>
        <li><span aria-current="page">Köpcentrum &amp; galleria</span></li>
      </ol>
    </div>
  </nav>

  <section class="hero" style="--hero-image:url('https://images.unsplash.com/photo-1519567281027-6152604e2599?auto=format&fit=crop&q=80&w=1800');">
    <div class="avab-container">
      <div class="hero-inner animate-in">
        <div class="eyebrow">Köpcentrum &amp; galleria</div>

        <h1>Tekniken som får hela huset att fungera</h1>

        <p class="lead">
          Ett köpcentrum är många verksamheter i samma fastighet: butiker, torg, garage, gångstråk, food court, drift, säkerhet och besökare. AVAB bygger tekniken som binder ihop allt – ljud, bild, signage, kameraövervakning och eventytor.
        </p>

        <div class="hero-bottom">
          <div class="hero-actions">
            <a class="button button-primary" href="/kontakt/">Boka teknisk genomgång</a>
            <a class="button button-secondary" href="#losningar">Se lösningarna</a>
            <a class="button button-quiet" href="#far-du">Det vi gör</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="procurement-strip">
    <div class="avab-container procurement-container">
      <span class="procurement-item">Bakgrundsljud i zoner</span>
      <span class="procurement-item">Signage &amp; LED</span>
      <span class="procurement-item">Kamera i hela huset</span>
      <span class="procurement-item">PA, tross &amp; torg</span>
    </div>
  </div>

  <main id="main">
    <section class="section section--light" id="kort-svar">
      <div class="avab-container two-col">
        <div class="snippet-box animate-in">
          <div class="eyebrow">Kort svar</div>
          <h2>Vad behöver ett modernt köpcentrum?</h2>
          <p>Ett modernt köpcentrum behöver teknik som skapar trygghet, flöde och upplevelse: zonstyrt bakgrundsljud, tydliga utrop, Digital Signage, totems, LED-väggar, kameraövervakning för hela fastigheten, garage- och parkeringslösningar samt PA och tross för torg och event.</p>
        </div>
        <div class="animate-in">
          <div class="eyebrow">Helhet</div>
          <h2>Inte separata system. En fungerande fastighet.</h2>
          <p class="lead-dark">När ljud, bild, kamera, signage och eventytor byggs var för sig blir drift, service och felsökning onödigt tungt. Vi projekterar helheten från ritning till färdig anläggning, så att fastighetsägare, driftpersonal, säkerhet och butikshyresgäster får en lösning som går att förstå, använda och vidareutveckla.</p>
          <ul class="summary-list">
            <li><strong>För fastighetsägaren</strong> Bättre överblick, tydligare hyresvärde, fler reklamytor och en teknisk plattform som kan växa.</li>
            <li><strong>För drift och säkerhet</strong> Färre separata system, snabbare felsökning, bättre dokumentation och tydligare ansvar.</li>
            <li><strong>För besökaren</strong> Tryggare miljö, enklare vägvisning, behagligare ljudbild och tydligare information.</li>
          </ul>
        </div>
      </div>
    </section>

    <section class="section" id="far-du">
      <div class="avab-container">
        <div class="section-heading animate-in">
          <div>
            <div class="eyebrow">Det vi levererar</div>
            <h2>Teknikområden som hänger ihop</h2>
            <p class="lead-dark">Vi kan ta hela uppdraget eller arbeta tillsammans med elektriker, byggare, säkerhetsbolag och fastighetens driftorganisation. Målet är alltid samma sak: rätt funktion, rätt placering, rätt dokumentation och teknik som håller över tid.</p>
          </div>
        </div>
        <div class="grid-3">
          <article class="feature-card animate-in">
            <span class="number" aria-hidden="true">01</span>
            <h3>Zonstyrt bakgrundsljud</h3>
            <p>Separata ljudzoner för entréer, gångstråk, food court, torg, toaletter, garage och serviceytor. Musik, utrop och volym anpassas efter miljön.</p>
          </article>
          <article class="feature-card animate-in">
            <span class="number" aria-hidden="true">02</span>
            <h3>Digital Signage &amp; totems</h3>
            <p>Väggmonterade skärmar, fristående totems, kampanjytor, butiksinformation, wayfinding och digitala budskap som går att styra centralt.</p>
          </article>
          <article class="feature-card animate-in">
            <span class="number" aria-hidden="true">03</span>
            <h3>LED-väggar</h3>
            <p>Stora visuella ytor för entréer, torg, event, reklam och varumärkesupplevelse där vanliga skärmar inte räcker till.</p>
          </article>
          <article class="feature-card animate-in">
            <span class="number" aria-hidden="true">04</span>
            <h3>Kameraövervakning</h3>
            <p>Projektering, montage, nätverk, dokumentation, funktionskontroll och service för hela fastigheten – inklusive garage och dolda riskytor.</p>
          </article>
          <article class="feature-card animate-in">
            <span class="number" aria-hidden="true">05</span>
            <h3>PA, tross &amp; torgscener</h3>
            <p>Fast eller tillfällig teknik för kampanjer, invigningar, mindre scener, modevisningar, artistframträdanden och lokala event.</p>
          </article>
          <article class="feature-card animate-in">
            <span class="number" aria-hidden="true">06</span>
            <h3>Service och livscykel</h3>
            <p>Dokumentation, serviceavtal, support, felsökning och uppgraderingar när butiker, flöden, säkerhetskrav och innehåll förändras.</p>
          </article>
        </div>
      </div>
    </section>

    <section class="section section--light" id="problem">
      <div class="avab-container two-col">
        <div class="animate-in">
          <div class="eyebrow">Utmaningen</div>
          <h2>En galleria är en stad i miniatyr</h2>
          <p class="lead-dark">Besökare rör sig mellan entréer, butiker, parkeringsytor, restauranger, torg och servicefunktioner. Samtidigt ska driftpersonal, väktare, centrumledning och hyresgäster kunna arbeta effektivt utan att fastna i krångliga system.</p>
          <p>Därför räcker det sällan att &quot;bara sätta upp några högtalare&quot; eller &quot;bara komplettera med några kameror&quot;. Det viktiga är hur tekniken planeras: var ljudet ska höras, var skärmar gör nytta, var kameror verkligen skapar överblick och hur allt dokumenteras för framtida drift.</p>
        </div>
        <aside class="card animate-in">
          <ul class="summary-list">
            <li><strong>Stora ytor kräver rätt täckning</strong> Gångstråk, torg och garage behöver olika typ av ljud, bild och kameravinklar.</li>
            <li><strong>Butikerna får inte störas</strong> Bakgrundsljud och utrop måste zonindelas så att helheten blir behaglig, inte påträngande.</li>
            <li><strong>Incidenter måste hittas snabbt</strong> Kameraövervakningen ska vara användbar i praktiken – inte bara spela in material som ingen orkar leta i.</li>
            <li><strong>Event ska gå att rigga smidigt</strong> Torgytor blir mer värdefulla när el, ljud, bild, tross och inkopplingar är planerade från början.</li>
          </ul>
        </aside>
      </div>
    </section>

