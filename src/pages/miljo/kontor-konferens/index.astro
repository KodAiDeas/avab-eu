---
import SiteHeader from "../../../components/SiteHeader.astro";
import "../../../styles/avab.css";
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Ljud & Bild för Konferensrum & Möten | AVAB</title>
  <meta name="description" content="Vi bygger modern konferensteknik med takmikrofoner, AI-kameror och trådlös BYOM-anslutning. Felfria hybridmöten för kontor, sessionssalar och co-working." />
  
  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "AVAB", "item": "https://avab.eu/" },
        { "@type": "ListItem", "position": 2, "name": "Miljöer", "item": "https://avab.eu/miljoer/" },
        { "@type": "ListItem", "position": 3, "name": "Konferens", "item": "https://avab.eu/miljoer/konferens-och-motesrum/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Måste man verkligen ha mikrofon i ett mindre konferensrum?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja, absolut. Det vanliga argumentet 'alla hör ju ändå' stämmer sällan, särskilt inte för distansdeltagare eller personer med hörselnedsättning i rummet. Med moderna takmikrofoner slipper ni skicka runt en handmikrofon – systemet fångar upp och förstärker allas röster automatiskt och osynligt."
          }
        },
        {
          "@type": "Question",
          "name": "Vad innebär BYOM (Bring Your Own Meeting)?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Det betyder att du kan ta med din egen bärbara dator in i rummet, ansluta trådlöst eller via en enda kabel, och direkt få tillgång till rummets professionella kameror, skärmar och ljudsystem oavsett om du kör Teams, Zoom eller Google Meet."
          }
        },
        {
          "@type": "Question",
          "name": "Hur säkerställer vi att tekniken fungerar i våra co-working-lokaler?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Genom centraliserad drift och nätverksövervakning. Vi kan se status på alla rum från en central skärm. Om en kabel dras ur eller en skärm tappar signal kan problemet åtgärdas innan nästa kund ens har gått in i rummet."
          }
        }
      ]
    }
  ]
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style>
    /* NÖDRAKETEN */
    .single-post .site-content .ast-container, .single-post .entry-content, .single-post .post-content { max-width: 100% !important; width: 100% !important; padding: 0 !important; margin: 0 !important; }
    .single-post .site-content { padding: 0 !important; }

    :root {
      --avab-green: #8FC025; 
      --avab-green-glow: rgba(143, 192, 37, 0.4);
      --avab-dark: #282E29;  
      --avab-dark-muted: #3A433D;
      --avab-grey: #E9EAE9;
      --avab-light: #F4F5F4;
      --avab-white: #ffffff; 
      --avab-border: rgba(40, 46, 42, 0.1);
      --avab-shadow-sm: 0 4px 12px rgba(40, 46, 42, 0.05);
      --avab-shadow-lg: 0 24px 48px rgba(40, 46, 42, 0.12);
      --avab-radius: 24px;
      --avab-radius-sm: 16px;
      --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body { font-family: 'Plus Jakarta Sans', system-ui, sans-serif; color: var(--avab-dark); background: var(--avab-white); line-height: 1.65; -webkit-font-smoothing: antialiased; }
    
    .container { width: min(calc(100% - 48px), 1280px); margin: 0 auto; }
    .section { padding: 56px 0; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-in { animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }

    /* Hero */
    .hero { 
      position: relative; padding: 120px 0 80px; 
      background: linear-gradient(135deg, rgba(40, 46, 42, 0.75) 0%, rgba(40, 46, 42, 0.65) 100%), 
                  url('https://images.unsplash.com/photo-1505373877841-8d25f7d46678?auto=format&fit=crop&q=80&w=1920') center/cover;
      color: #ffffff !important; 
    }
    .hero h1 { color: #ffffff !important; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 800; line-height: 1.1; margin-bottom: 24px; max-width: 25ch; }
    .hero p { color: #ffffff !important; font-size: 1.25rem; max-width: 68ch; opacity: 0.95; margin-bottom: 0; }

    .eyebrow { display: inline-flex; align-items: center; gap: 10px; padding: 8px 16px; border-radius: 999px; background: var(--avab-green); color: var(--avab-dark); font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 24px; }
    .eyebrow::before { content: ""; width: 8px; height: 8px; border-radius: 50%; background: #ffffff; }

    h2 { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 700; margin-bottom: 16px; line-height: 1.15; }
    .lead-dark { font-size: 1.15rem; max-width: 68ch; color: var(--avab-dark-muted); margin-bottom: 20px; }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
    
    .summary-list { display: grid; gap: 16px; list-style: none; margin-top: 62px; }
    .summary-list li { padding: 24px 20px; border-radius: var(--avab-radius-sm); background: var(--avab-white); box-shadow: var(--avab-shadow-sm); border: 1px solid var(--avab-border); }
    .summary-list strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.15rem; }

    /* Solutions Grid med Expand/Collapse */
    .solutions-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin-top: 24px; }
    .solution-card { padding: 40px; border-radius: var(--avab-radius); background: var(--avab-white); border: 1px solid var(--avab-border); transition: var(--transition-smooth); display: flex; flex-direction: column; position: relative; }
    .solution-card:hover { transform: translateY(-8px); box-shadow: var(--avab-shadow-lg); border-color: var(--avab-green); }
    
    .solution-card-top { flex-grow: 1; display: flex; flex-direction: column; }
    .solution-card h3 { font-weight: 800; margin-bottom: 16px; font-size: 1.5rem; min-height: 3.6rem; }
    .solution-card .intro-text { margin-bottom: 24px; color: var(--avab-dark-muted); font-size: 1.05rem; line-height: 1.6; }

    .solution-card-bottom { margin-top: auto; }
    .solution-expandable { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.4s cubic-bezier(0.25, 1, 0.5, 1); }
    .solution-expand-inner { overflow: hidden; opacity: 0; transition: opacity 0.3s ease; }
    .solution-card:hover .solution-expandable { grid-template-rows: 1fr; }
    .solution-card:hover .solution-expand-inner { opacity: 1; }

    .hover-indicator { display: grid; grid-template-rows: 1fr; transition: grid-template-rows 0.4s ease, padding 0.4s ease; border-top: 1px solid var(--avab-border); padding-top: 20px; }
    .solution-card:hover .hover-indicator { grid-template-rows: 0fr; padding-top: 0; border-top-color: transparent; }
    .solution-card:hover .hover-indicator div { opacity: 0; }

    .bullet-list { list-style: none; margin-top: 20px; }
    .bullet-list li { position: relative; padding-left: 28px; margin-bottom: 12px; font-weight: 500; font-size: 0.95rem; color: var(--avab-dark-muted); }
    .bullet-list li::before { content: "✓"; position: absolute; left: 0; color: var(--avab-green); font-weight: 800; }
    .cat-link { color: var(--avab-dark); font-weight: 800; text-decoration: none; border-bottom: 2px solid var(--avab-green); }

    /* Flow / Pris / Ref */
    .flow-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 40px; }
    .flow-card { padding: 24px; border-radius: var(--avab-radius-sm); background: var(--avab-white); border: 1px solid var(--avab-border); }
    .flow-card strong { display: block; min-height: 3.2rem; color: var(--avab-green); font-size: 1.05rem; margin-bottom: 12px; line-height: 1.4; }
    .flow-card span { font-size: 0.95rem; color: var(--avab-dark-muted); min-height: 4.5rem; display: block; line-height: 1.5; }

    .pricing-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin-top: 40px; }
    .pricing-card { padding: 40px; border-radius: var(--avab-radius); background: var(--avab-white); border: 1px solid var(--avab-border); transition: var(--transition-smooth); }
    .pricing-card h3 { font-size: 2.2rem; font-weight: 800; margin: 16px 0; }
    .pricing-card p { color: var(--avab-dark-muted); line-height: 1.6; margin-bottom: 0; font-size: 1.05rem; }
    .pricing-card.highlight { border: 2px solid var(--avab-green); }

    .ref-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 24px; margin-top: 40px; }
    .ref-card { overflow: hidden; border-radius: var(--avab-radius); border: 1px solid var(--avab-border); background: var(--avab-white); display: flex; flex-direction: column; transition: var(--transition-smooth); }
    .ref-card:hover { transform: translateY(-5px); box-shadow: var(--avab-shadow-lg); border-color: var(--avab-green); }
    .ref-card img { width: 100%; height: 240px; object-fit: cover; }
    .ref-content { padding: 32px; flex-grow: 1; }
    .ref-content h3 { font-size: 1.4rem; margin-bottom: 12px; }
    .ref-content p { font-size: 1rem; color: var(--avab-dark-muted); line-height: 1.6; margin-bottom: 0; }

    .faq-list { display: grid; gap: 16px; }
    .faq-item { padding-top: 16px; border-top: 1px solid var(--avab-border); }
    .faq-item:first-child { border-top: 0; padding-top: 0; }
    .faq-item h3 { font-size: 1.25rem; margin-bottom: 12px; font-weight: 700; }
    .faq-item p { color: var(--avab-dark-muted); line-height: 1.6; font-size: 1.1rem; margin-bottom: 0; }

    .cta-card { background: linear-gradient(135deg, var(--avab-dark) 0%, #2A332C 50%, var(--avab-green) 100%); color: var(--avab-white); padding: 48px; border-radius: var(--avab-radius); display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden; }
    .cta-card h2 { color: var(--avab-white); }
    .cta-card p { color: var(--avab-white); line-height: 1.6; margin-bottom: 0; font-size: 1.1rem; }
    @media (min-width: 1081px) { #faq .cta-card { margin-top: 62px; } }
    .button { display: inline-flex; align-items: center; justify-content: center; min-height: 56px; padding: 0 32px; border-radius: 999px; font-weight: 700; background: var(--avab-green); color: var(--avab-dark); text-decoration: none; transition: var(--transition-smooth); font-size: 1.05rem; }
    .button:hover { transform: translateY(-2px); box-shadow: 0 16px 32px var(--avab-green-glow); }
    
    @media (max-width: 1080px) { .two-col, .ref-grid { grid-template-columns: 1fr; } .summary-list { margin-top: 24px; } }
    @media (max-width: 768px) {
      .hero { padding: 100px 0 60px; } .section { padding: 40px 0; } 
      .solution-card h3 { min-height: auto; } .solution-expandable { grid-template-rows: 1fr; } .hover-indicator { display: none; } .solution-expand-inner { opacity: 1; }
      .flow-card strong, .flow-card span { min-height: auto; } 
    }
  </style>
</head>
<body>
  <SiteHeader />

  <header class="hero">
    <div class="container animate-in">
      <div class="eyebrow">Miljö: Konferens & Mötesrum</div>
      <h1>Teknisk intelligens för framtidens mötesrum</h1>
      <p>I en värld av hybridarbete är tekniken själva ryggraden i mötet. Vi bygger intuitiva konferensrum med osynliga takmikrofoner, AI-kameror och sömlös BYOM-anslutning.</p>
      <div style="margin-top: 40px;"><a class="button" href="/kontakt/">Boka kostnadsfri rådgivning</a></div>
    </div>
  </header>

  <section class="fact-band" aria-label="Snabbfakta kontor och konferens">
    <div class="fact-grid">
      <div class="fact"><span>Miljö</span><strong>Kontor och mötesrum</strong></div>
      <div class="fact"><span>Ljud</span><strong>Mikrofoner och taltydlighet</strong></div>
      <div class="fact"><span>Bild</span><strong>Skärm, kamera och delning</strong></div>
      <div class="fact"><span>Styrning</span><strong>Ett tryck startar rummet</strong></div>
      <div class="fact"><span>Standard</span><strong>Samma flöde i alla rum</strong></div>
      <div class="fact"><span>Leverans</span><strong>Ritning till driftsatt möte</strong></div>
    </div>
  </section>

  <main>
    <section class="section" style="border-bottom: 1px solid var(--avab-border);">
      <div class="container two-col">
        <div class="animate-in">
          <div class="eyebrow">Verkligheten</div>
          <h2>"Alla hör ju ändå" – en myt som dödar mötet</h2>
          <p class="lead-dark">Ett av de vanligaste problemen i mötesrum är bristen på tillgänglighet. Någon suckar och säger <em>"vi behöver ingen mikrofon, alla hör ju ändå"</em>. Nej, de gör ju faktiskt inte det. Särskilt inte distansdeltagare eller personer i rummet med hörselnedsättning.</p>
          <p class="lead-dark">Samtidigt lider många rum av "teknikstress" – fel kablar, adaptrar som saknas och krångliga menyer. AVAB bygger rum där tekniken gör jobbet åt er. Ljudet plockas upp osynligt, ekot försvinner via avancerad DSP och skärmarna startar automatiskt.</p>
        </div>
        <aside class="animate-in" style="animation-delay: 0.1s;">
          <ul class="summary-list">
            <li><strong>Den hybrida standarden</strong> Nästan alla möten idag har distansdeltagare. Det kräver extrem mikrofonteknik för att eliminera rums-eko och brus.</li>
            <li><strong>Inkludering som fungerar</strong> Att skicka runt en mikrofon bryter mötets dynamik. Takmikrofoner löser problemet automatiskt – för alla i rummet och på länk.</li>
            <li><strong>Driftsäkerhet i Co-working</strong> Trasiga mötesrum kostar pengar. Vi bygger in fjärrövervakning så fel upptäcks innan nästa kund kliver in.</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container">
        <div class="section-header animate-in">
          <div class="eyebrow">Våra 4 pelare</div>
          <h2 style="margin-bottom: 16px;">Bakom kulisserna i rummet</h2>
        </div>
        <div class="solutions-grid">
          
          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Voice Lift & Tillgänglighet</h3>
              <p class="intro-text">Vi använder takmikrofoner med "beamforming" som följer den som talar. Ljudet förstärks osynligt i rummet och skickas direkt till teleslinga och distansdeltagare.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div style="font-weight:800; color:var(--avab-green); text-transform:uppercase; font-size:0.75rem; letter-spacing:0.05em;">Läs om ljud ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/ljudsystem/" class="cat-link">Voice Lift:</a> Slut på rundskickade mikrofoner</li>
                    <li><a href="/ljudsystem/" class="cat-link">DSP / AEC:</a> Eliminerar eko i hybridmöten</li>
                    <li><a href="/losningar/horslingor/" class="cat-link">Inkludering:</a> Perfekt ljud till hörapparater</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Bild & AI-Kameror</h3>
              <p class="intro-text">Vi använder ljusstarka skärmar och AI-kameror som automatiskt zoomar in på den som pratar och ramar in hela gruppen perfekt utan fjärrkontroll.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div style="font-weight:800; color:var(--avab-green); text-transform:uppercase; font-size:0.75rem; letter-spacing:0.05em;">Läs om bild ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/bild/" class="cat-link">Autoframing:</a> Kameran följer talaren med AI</li>
                    <li><a href="/bild/" class="cat-link">Videobars:</a> All-in-one enheter för mellanstora rum</li>
                    <li><a href="/bild/" class="cat-link">Skärmar:</a> Skarpa skärmar i alla ljusförhållanden</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Styrsystem & BYOM</h3>
              <p class="intro-text">Ta med din egen dator, anslut trådlöst eller med en USB-C, och få direkt tillgång till rummets kamera och ljud (BYOM). Enkelhet i världsklass.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div style="font-weight:800; color:var(--avab-green); text-transform:uppercase; font-size:0.75rem; letter-spacing:0.05em;">Läs om styrsystem ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/styrsystem/" class="cat-link">Plug & Play:</a> Starta rummet med en kabel</li>
                    <li><a href="/styrsystem/" class="cat-link">BYOM:</a> Bring Your Own Meeting-teknik</li>
                    <li><a href="/styrsystem/" class="cat-link">Paneler:</a> Touchpaneler (t.ex. Crestron/Extron)</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Infrastruktur & Drift</h3>
              <p class="intro-text">Grunden styrs via nätverket (AV-over-IP & Dante). Vi övervakar systemen centralt och använder närvarosensorer för att stänga av teknik i tomma rum.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div style="font-weight:800; color:var(--avab-green); text-transform:uppercase; font-size:0.75rem; letter-spacing:0.05em;">Läs om nätverk ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/losningar/systemintegration/" class="cat-link">AV-over-IP:</a> Skicka bild och ljud var som helst</li>
                    <li><a href="/losningar/systemintegration/" class="cat-link">Övervakning:</a> Fjärrkontroll för co-working</li>
                    <li><a href="/styrsystem/" class="cat-link">Smarta rum:</a> Sensorer för energibesparing</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>
        </div>

        <div class="flow-grid animate-in">
          <div class="flow-card"><strong>Takmikrofon → Jämställdhet</strong><span>Alla i rummet hörs lika bra, oavsett om de står vid whiteboarden eller sitter längst bak.</span></div>
          <div class="flow-card"><strong>USB-C/BYOM → Enkelhet</strong><span>Ingen frustration över fel kablar. Ett uttag sköter laddning, bild, ljud och kamera.</span></div>
          <div class="flow-card"><strong>AV-over-IP → Skalbarhet</strong><span>Möjliggör att enkelt koppla ihop ljud och bild i tre konferensrum till en stor eventyta.</span></div>
        </div>
      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--avab-border); background: var(--avab-white);">
      <div class="container animate-in">
        <div class="section-header">
          <div class="eyebrow">Investering</div>
          <h2 style="margin-bottom: 16px;">Vad kostar professionella mötesrum?</h2>
          <p class="lead-dark" style="margin-bottom: 40px;">Priset styrs av storleken på rummen, graden av styrsystem och om ni har behov av avancerad Voice Lift-teknik. Här är en grov uppskattning för budgetering.</p>
        </div>
        <div class="pricing-grid">
          <div class="pricing-card">
            <div class="eyebrow" style="background: var(--avab-light); color: var(--avab-dark-muted); border: 1px solid var(--avab-border);">Mindre mötesrum</div>
            <h3>100–250 kkr</h3>
            <p>För huddle rooms och kontorsrum. Fokus på skarpa skärmar, "all-in-one" videobars med inbyggd AI-kamera och trådlös eller USB-C-anslutning.</p>
          </div>
          <div class="pricing-card highlight">
            <div class="eyebrow">Konferens & Co-working</div>
            <h3>250–600 kkr</h3>
            <p>Standardrum för 8–14 personer. Integrerade touchpaneler (t.ex. Crestron), dedikerade takmikrofoner och avancerad DSP för eko-fria hybridmöten.</p>
          </div>
          <div class="pricing-card">
            <div class="eyebrow" style="background: var(--avab-light); color: var(--avab-dark-muted); border: 1px solid var(--avab-border);">Sessionssalar & Center</div>
            <h3>600 kkr +</h3>
            <p>Stora salar med röstförstärkning (Voice Lift), multipla AI-kameror, AV-over-IP för att knyta samman flera rum och centraliserad övervakning.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--avab-border);">
      <div class="container">
        <div class="eyebrow">Kontorsreferenser</div>
        <h2>Teknik som stärker samarbetet</h2>
        <div class="ref-grid animate-in">
          <article class="ref-card">
            <img src="https://images.unsplash.com/photo-1517502884422-41eaead166d4?auto=format&fit=crop&q=80&w=800" alt="Lesjöfors AB styrelserum konferensteknik">
            <div class="ref-content">
              <h3>Lesjöfors AB</h3>
              <p>Ett modernt konferensrum utrustat med en 86" skärm och Q-sys-teknik. Rummet använder en avancerad takmikrofon, trådlös överföring av ljud och bild samt stilrent infällda takhögtalare för en helt kabelfri upplevelse.</p>
            </div>
          </article>
          <article class="ref-card">
