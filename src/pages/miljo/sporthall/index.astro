  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Delad designsystem-CSS -->
  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- Lösningskort (grön ram, accentkant) ---- */
    .solution-card {
      border: 2px solid rgba(143, 192, 37, 0.62);
      box-shadow: 0 18px 42px rgba(143, 192, 37, 0.12);
      position: relative;
      overflow: hidden;
    }
    .solution-card::before {
      content: "";
      position: absolute;
      inset: 0 auto 0 0;
      width: 8px;
      background: var(--avab-green);
    }
    .solution-card h3,
    .solution-card .bullet-list { position: relative; z-index: 1; }

    /* ---- Inre länk i referenskort ("Se referensprojekt →") ---- */
    .ref-content a {
      margin-top: auto;
      font-weight: 800;
      color: var(--avab-dark);
    }
    .ref-content a:hover { color: var(--avab-green); }
    .ref-content a::after { content: " →"; color: var(--avab-green); }

    /* ---- Kalkylband (mitt på sidan) ---- */
    .calculator-band {
      margin-top: 30px;
      padding: 28px;
      border-radius: var(--avab-radius-sm);
      background:
        radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 34%),
        linear-gradient(135deg, #425c19 0%, #6f9f1f 52%, var(--avab-green) 100%);
      border: 1px solid rgba(255, 255, 255, 0.18);
      box-shadow: 0 18px 34px rgba(40, 46, 42, 0.18);
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 20px;
      align-items: center;
    }
    .calculator-band h3 { color: #fff; font-size: 1.35rem; margin-bottom: 6px; }
    .calculator-band p { margin-bottom: 0; color: rgba(255, 255, 255, 0.9); font-size: 1rem; max-width: 760px; }
    .calculator-band .button {
      background: #fff;
      color: var(--avab-dark);
      box-shadow: 0 14px 28px rgba(40, 46, 42, 0.18);
    }
    .calculator-band .button:hover { background: var(--avab-dark); color: #fff; }

    /* ---- FAQ: vänsterställd rubrik + tvåkolumnslayout ---- */
    .faq-heading { max-width: 760px; margin: 0 0 30px; text-align: left; }
    .faq-heading .eyebrow { margin-left: 0; margin-right: 0; }
    .faq-heading h2 { margin-bottom: 12px; max-width: 680px; }
    .faq-heading p { color: var(--avab-dark-muted); margin-bottom: 0; max-width: 760px; }

    .compact-faq {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 0;
      max-width: 1060px;
      margin: 0 auto;
    }
    .compact-faq details.faq-item { padding: 20px 0; }
    .compact-faq summary { font-size: 1.05rem; }
    .compact-faq details.faq-item p { font-size: 0.98rem; }
    .compact-faq details.faq-item:nth-child(1),
    .compact-faq details.faq-item:nth-child(2) { border-top: 1px solid var(--avab-border); }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 768px) {
      .calculator-band { grid-template-columns: 1fr; padding: 24px; }
      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
        <li><a href="https://www.avab.eu/">Start</a></li>
        <li><a href="https://www.avab.eu/#miljoer">Miljöer</a></li>
        <li><span aria-current="page">Sporthall & arena</span></li>
      </ol>
