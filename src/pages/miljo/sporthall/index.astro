  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad behöver en sporthall för AV-teknik?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En sporthall behöver ofta ljudanläggning, mikrofoner, zonstyrning, hörslinga eller Auracast, STI-dokumentation och enkel styrning för personal och föreningar."
        }
      },
      {
        "@type": "Question",
        "name": "Kan ljudet delas mellan A-hall och B-hall?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Med rätt zonlogik kan hallen fungera separat i A-hall och B-hall, eller som helsal när ridåväggen är öppen."
        }
      },
      {
        "@type": "Question",
        "name": "Kan elektriker installera efter AVAB:s underlag?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB kan projektera och driftsätta, medan elektriker installerar efter underlag. AVAB kan också installera hela lösningen."
        }
      },
      {
        "@type": "Question",
        "name": "Vad kostar AV-teknik till en sporthall?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kostnaden beror på halltyp, zoner, styrning, mikrofoner, hörslinga, läktare, STI-krav och installation. AVAB:s sporthallskalkylator kan ge en tidig budgetnivå."
        }
      },
      {
        "@type": "Question",
        "name": "När bör AV-tekniken komma in i byggprojektet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AV-tekniken bör komma in innan kabelvägar, golv, rackplats och upphandlingskrav är låsta. Det minskar risken för sena kompletteringar."
        }
      },
      {
        "@type": "Question",
        "name": "Behöver en sporthall hörslinga eller Auracast?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ofta behöver tillgänglighet planeras tidigt. Hörslinga kan vara rätt för plan och läktare, medan Auracast kan vara ett komplement för publika ytor."
        }
      },
      {
        "@type": "Question",
        "name": "Vad betyder STI i en sporthall?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "STI är ett mått på taluppfattbarhet. Om upphandling eller FFU anger STI-krav behöver ljudsystemet projekteras, mätas in och dokumenteras."
        }
      }
    ]
  }
  </script>

