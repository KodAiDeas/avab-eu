        "@type": "PostalAddress",
        "streetAddress": "Skraggevägen 4",
        "postalCode": "663 41",
        "addressLocality": "Hammarö",
        "addressRegion": "Värmland",
        "addressCountry": "SE"
      }
    },
    "areaServed": "Sverige",
    "serviceType": [
      "Ljudanläggning sporthall",
      "AV-teknik idrottshall",
      "Sporthallsteknik",
