    href="https://images.unsplash.com/photo-1580748141549-71748dbe0bdc?auto=format&fit=crop&q=80&w=1800">

  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Delad designsystem-CSS -->
  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- Problem-/sammanfattningslista (kortrutor) ---- */
    .summary-list { display: grid; gap: 16px; list-style: none; margin: 0; }
    .summary-list li {
      padding: 22px 20px;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
      font-size: 1rem;
      color: var(--avab-dark-muted);
      border: 1px solid var(--avab-border);
      line-height: 1.55;
    }
    .summary-list strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.12rem; line-height: 1.2; }

    /* ---- Lösningskort med hover/fokus-expandering ---- */
    .solutions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
      gap: 24px;
    }
    .solution-card {
      padding: 36px;
      border-radius: var(--avab-radius);
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      box-shadow: var(--avab-shadow-sm);
      transition: var(--transition-smooth);
      display: flex;
      flex-direction: column;
      height: 100%;
    }
    .solution-card:hover,
    .solution-card:focus-within {
      transform: translateY(-8px);
      box-shadow: var(--avab-shadow-lg);
      border-color: var(--avab-green);
    }
    .solution-card-top { flex-grow: 1; }
    .solution-card h3 { font-weight: 800; margin-bottom: 14px; font-size: 1.4rem; color: var(--avab-dark); line-height: 1.2; }
    .solution-card .intro-text { margin-bottom: 22px; font-size: 1.02rem; color: var(--avab-dark-muted); line-height: 1.6; }
    .solution-card-bottom { margin-top: auto; }

    .solution-expandable {
      display: grid;
      grid-template-rows: 0fr;
      transition: grid-template-rows 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    }
    .solution-expand-inner { overflow: hidden; opacity: 0; transition: opacity 0.3s ease; }
    .solution-card:hover .solution-expandable,
    .solution-card:focus-within .solution-expandable { grid-template-rows: 1fr; }
    .solution-card:hover .solution-expand-inner,
    .solution-card:focus-within .solution-expand-inner { opacity: 1; }

    .hover-indicator {
      display: grid;
      grid-template-rows: 1fr;
      transition: grid-template-rows 0.4s ease, padding 0.4s ease;
      border-top: 1px solid var(--avab-border);
      padding-top: 18px;
    }
    .hover-indicator > div {
      font-weight: 800;
      color: var(--avab-dark);
      text-transform: uppercase;
      font-size: 0.75rem;
      letter-spacing: 0.05em;
    }
    .solution-card:hover .hover-indicator,
    .solution-card:focus-within .hover-indicator { grid-template-rows: 0fr; padding-top: 0; border-top-color: transparent; }
    .solution-card:hover .hover-indicator > div,
    .solution-card:focus-within .hover-indicator > div { opacity: 0; }

    /* Mindre punkter i lösningskorten */
    .solution-card .bullet-list { margin-top: 4px; }
    .solution-card .bullet-list li { font-size: 0.95rem; font-weight: 500; padding-left: 28px; }

    /* Interna länkar i lösningskorten (tillgänglig kontrast) */
    .cat-link {
      color: var(--avab-dark);
      font-weight: 800;
      text-decoration: none;
      border-bottom: 2px solid var(--avab-green);
      transition: var(--transition-smooth);
    }
    .cat-link:hover { background: var(--avab-green); color: #fff; }
    .kw-link {
      color: var(--avab-dark);
      font-weight: 700;
      text-decoration: underline;
      text-decoration-color: var(--avab-green);
      text-underline-offset: 3px;
    }
    .kw-link:hover { text-decoration-color: var(--avab-dark); }

    /* ---- Synergi: flödeskort (grön etikett, ej numrerad) ---- */
    .flow-grid .flow-card strong { display: block; color: var(--avab-green); font-size: 1.05rem; line-height: 1.4; margin-bottom: 10px; }
    .flow-grid .flow-card span { display: block; color: var(--avab-dark-muted); font-size: 0.95rem; line-height: 1.5; }

    /* ---- Vertikalt CTA-kort (mörk gradient) bredvid FAQ ---- */
    .cta-card {
      background: linear-gradient(135deg, var(--avab-dark) 0%, #2A332C 50%, var(--avab-green) 100%);
      color: #fff;
      padding: 48px;
      border-radius: var(--avab-radius);
      box-shadow: var(--avab-shadow-lg);
      display: flex;
      flex-direction: column;
      justify-content: center;
      height: 100%;
    }
    .cta-card h2 { color: #fff; margin-bottom: 16px; }
    .cta-card p { color: rgba(255, 255, 255, 0.92); line-height: 1.6; margin-bottom: 0; font-size: 1.1rem; }
    .cta-card .eyebrow { background: rgba(0, 0, 0, 0.2); color: #fff; border: 1px solid rgba(255, 255, 255, 0.16); }
    .cta-card .eyebrow::before { background: var(--avab-green); box-shadow: none; }
    .cta-card .calc-list { margin: 24px 0 0; }

    /* ---- FAQ-lista (enkolumn, dragspel via gemensam CSS) ---- */
    .faq-list { margin-top: 8px; }

    @media (max-width: 768px) {
      /* På mobil: visa lösningskortens innehåll direkt (inget hover) */
      .solution-expandable { grid-template-rows: 1fr; }
      .solution-expand-inner { opacity: 1; }
      .hover-indicator { display: none; }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
        <li><a href="https://www.avab.eu/">Start</a></li>
        <li><a href="https://www.avab.eu/#miljoer">Miljöer</a></li>
        <li><span aria-current="page">Ishall &amp; arena</span></li>
      </ol>
    </div>
  </nav>

  <section class="hero" style="--hero-image:url('https://images.unsplash.com/photo-1580748141549-71748dbe0bdc?auto=format&fit=crop&q=80&w=1800');">
    <div class="avab-container">
      <div class="hero-inner animate-in">
        <div class="eyebrow">Ishall &amp; arena</div>

        <h1>Ljudsystem som övervinner ekot och kylan</h1>

        <p class="lead">
          Vi projekterar robust teknik för ishallar. Från fuktskyddad hårdvara och tempererade teknikrum till extrem direktivitet som garanterar en oslagbar stämning på läktaren.
        </p>

        <div class="hero-bottom">
          <div class="hero-actions">
            <a class="button button-primary" href="/kontakt/">Boka kostnadsfri rådgivning</a>
            <a class="button button-secondary" href="#losningar">Se lösningarna</a>
          </div>
        </div>
      </div>
    </div>
  </section>
  <section class="fact-band" aria-label="Snabbfakta ishall">
    <div class="fact-grid">
      <div class="fact"><span>Miljö</span><strong>Ishall &amp; arena</strong></div>
      <div class="fact"><span>Ljud</span><strong>Tal, matchintro och måltuta</strong></div>
      <div class="fact"><span>Material</span><strong>Passivt och IP-klassat</strong></div>
      <div class="fact"><span>Akustik</span><strong>EASE-simulering och STI</strong></div>
      <div class="fact"><span>Trygghet</span><strong>Talat utrymningslarm</strong></div>
      <div class="fact"><span>Leverans</span><strong>Projektering till drift</strong></div>
    </div>
  </section>
    <main id="main">
    <section class="section" id="utmaning">
      <div class="avab-container two-col">
        <div class="animate-in">
          <div class="eyebrow">Verkligheten</div>
          <h2>Ett akustiskt inferno</h2>
          <p class="lead-dark">En ishall är en av de svåraste miljöerna att bygga ljud för. Stora ytor av is, betong, plåttak och plexiglas fungerar som speglar för ljudet, vilket skapar en massiv efterklang. Orden flyter ihop och informationen försvinner.</p>
          <p class="lead-dark">Ovanpå detta tillkommer fukten och kylan som obönhörligt bryter ner felvald elektronik. Lösningen är inte högre volym, utan smartare kabeldragning, passiva system och kirurgisk precision i ljudets riktning.</p>
        </div>

        <aside class="animate-in">
          <ul class="summary-list">
            <li>
              <strong>Kondens förstör aktiv elektronik</strong>
              Ett vanligt misstag är att använda aktiva högtalare i hallen. Kondensdroppar från taket kortsluter dem snabbt. Vi bygger alltid med passiva system och gömmer elektroniken i varma teknikrum.
            </li>
            <li>
              <strong>Att höra är inte att förstå</strong>
              Ett system med hög volym är värdelöst om orden grötas ihop av ekon från isen. Vi projekterar efter mätbar taluppfattbarhet (STI).
            </li>
            <li>
              <strong>Matchintro under press</strong>
              För en komplett upplevelse krävs att musik, måltuta, belysning och effekter synkar – och att sekretariatet enkelt kan styra det.
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section section--light" id="losningar">
      <div class="avab-container">
        <div class="section-heading animate-in">
          <div>
            <div class="eyebrow">Våra lösningar</div>
            <h2>Det digitala ekosystemet</h2>
            <p class="lead-dark">Här är de fyra pelarna som gör er ishall redo för allt från konståkning till elitderby.</p>
          </div>
        </div>

        <div class="solutions-grid">
          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Fukttåliga system</h3>
              <p class="intro-text">Genom att använda passiva, IP-klassade högtalare ute i hallen och placera förstärkarna i ett plusgradigt teknikrum eliminerar vi risken för fuktskador.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div>Se utomhusljud ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/tjanster/taluppfattbarhet/" class="cat-link">Ljud:</a> Passiva och IP-klassade högtalare</li>
                    <li><span class="kw-link">Infrastruktur:</span> Rätt dimensionerade kablar</li>
                    <li><span class="cat-link">Driftsäkerhet:</span> Förstärkare i tempererade rum</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Garanterad taluppfattbarhet</h3>
              <p class="intro-text">Vi designar system med extrem direktivitet. Ljudet "skjuts" exakt på publiken istället för att studsa okontrollerat mot isen och plexiglaset.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div>Läs om ljudteknik ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/tjanster/taluppfattbarhet/" class="cat-link">Mätning:</a> <a href="/tjanster/taluppfattbarhet/" class="kw-link">STIPA-analys</a></li>
                    <li><span class="cat-link">EASE:</span> Akustisk 3D-simulering av arenan</li>
                    <li><a href="/tjanster/horslinga/" class="cat-link">Tillgänglighet:</a> Slingor för publik med nedsatt hörsel</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Matchintro &amp; upplevelse</h3>
              <p class="intro-text">Bygg upp stämningen i hallen. Vi integrerar dånande mållåtar, nedsläckt ljus, moving heads och måltutor i ett enda smidigt gränssnitt.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div>Utforska effekter ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><span class="cat-link">Effekter:</span> DMX-styrd belysning och rök</li>
                    <li><a href="/tjanster/taluppfattbarhet/" class="kw-link">Kraft:</a> Subwoofers för tryck i musiken</li>
                    <li><span class="cat-link">Bild:</span> Synkning med jumbotron / LED</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Trygghet &amp; utrymningslarm</h3>
              <p class="intro-text">Ett ishockeyderby har enorma ljudvolymer. Vid fara måste talade instruktioner kunna bryta igenom publikens jubel utan fördröjning.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div>Läs om säkerhet ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><span class="cat-link">TUL:</span> Talat utrymningslarm i EN 54-standard</li>
                    <li><span class="cat-link">Prioritet:</span> Larmet stänger automatiskt av musiken</li>
                    <li><a href="/tjanster/kameraovervakning/" class="cat-link">Säkerhet:</a> Kameror för crowd-control</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>
        </div>

        <div class="flow-grid animate-in">
          <div class="flow-card"><strong>Teknikrum → Driftsäkerhet</strong><span>Att isolera förstärkarna i ett varmt utrymme minimerar risken för fuktkortslutningar.</span></div>
          <div class="flow-card"><strong>Direktivitet → Akustik</strong><span>Att rikta högtalarna bort från isen är avgörande för att bekämpa hallens eko.</span></div>
          <div class="flow-card"><strong>Styrsystem → Personal</strong><span>Sekretariatet sköter all teknik, från utvisningsmusik till måltuta, från en enda skärm.</span></div>
        </div>
      </div>
    </section>

    <section class="section" id="referenser">
      <div class="avab-container">
        <div class="section-heading animate-in">
          <div>
            <div class="eyebrow">Arenareferenser</div>
            <h2>Teknik som tål minusgrader</h2>
            <p class="lead-dark">AVAB arbetar med ishallar, arenor, sporthallar och andra publika miljöer där ljud, styrning och säkerhet måste fungera i tuffa förhållanden. Närliggande sidor: <a class="text-link" href="/miljo/sporthall/">sporthall &amp; arena</a>, <a class="text-link" href="/miljo/simhall/">simhall</a> och <a class="text-link" href="/tjanster/taluppfattbarhet/">taluppfattbarhet</a>.</p>
          </div>
        </div>
        <div class="ref-grid">
          <article class="ref-card animate-in">
            <img src="/assets/Hammaro ishall 1200x900.webp" alt="Hammarö ishall ljudsystem och akustik" width="900" height="600" loading="lazy" decoding="async">
            <div class="ref-content">
              <h3>Hammarö ishall, Värmland</h3>
