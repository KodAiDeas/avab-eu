---
import SiteHeader from "../../../components/SiteHeader.astro";
import "../../../styles/avab.css";
---

<!DOCTYPE html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Tekniklösningar för Skola – Integrerat Ljud, Bild & Säkerhet | AVAB</title>
  <meta name="description" content="AVAB levererar framtidens lärmiljöer. Vi integrerar rastsignaler, aulateknik, röstförstärkning och säkerhetssystem för en tryggare och effektivare skola." />
  
  <script type="application/ld+json">
  [
    {
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "AVAB", "item": "https://avab.eu/" },
        { "@type": "ListItem", "position": 2, "name": "Miljöer", "item": "https://avab.eu/miljoer/" },
        { "@type": "ListItem", "position": 3, "name": "Skola", "item": "https://avab.eu/skola/" }
      ]
    },
    {
      "@context": "https://schema.org",
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": "Kan vi använda befintliga högtalare vid en uppgradering i skolan?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Ja, vid retrofit-projekt kan vi ofta återanvända befintligt kablage och fungerande högtalare genom att installera moderna centralenheter som Schoolbell med XLR och USB-C kontakter."
          }
        },
        {
          "@type": "Question",
          "name": "Är rastsignalsystemet certifierat som ett brandlarm?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Våra rastsignalsystem är informationssystem. För certifierad säkerhet levererar och projekterar vi Talat Utrymningslarm (TUL/UTM) som följer EN-54 standarden för livräddande utrustning."
          }
        }
      ]
    }
  ]
  </script>

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style>
    /* NÖDRAKETEN: Tvingar fullbredd i Astra */
    .single-post .site-content .ast-container, .single-post .entry-content, .single-post .post-content { max-width: 100% !important; width: 100% !important; padding: 0 !important; margin: 0 !important; }
    .single-post .site-content { padding: 0 !important; }

    :root {
      --avab-green: #8FC025; 
      --avab-green-glow: rgba(143, 192, 37, 0.4);
      --avab-dark: #282E29;  
      --avab-dark-muted: #3A433D;
      --avab-grey: #E9EAE9;  
      --avab-white: #ffffff; 
      --avab-border: rgba(40, 46, 42, 0.1);
      --avab-shadow-sm: 0 4px 12px rgba(40, 46, 42, 0.05);
      --avab-shadow-lg: 0 24px 48px rgba(40, 46, 42, 0.12);
      --avab-radius: 24px;
      --avab-radius-sm: 16px;
      --transition-smooth: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    html { scroll-behavior: smooth; }
    body { font-family: 'Plus Jakarta Sans', system-ui, -apple-system, sans-serif; color: var(--avab-dark); background: var(--avab-white); line-height: 1.65; -webkit-font-smoothing: antialiased; }
    
    .container { width: min(calc(100% - 48px), 1280px); margin: 0 auto; }
    .section { padding: 56px 0; }

    @keyframes fadeUp { from { opacity: 0; transform: translateY(20px); } to { opacity: 1; transform: translateY(0); } }
    .animate-in { animation: fadeUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards; }

    /* Hero */
    .hero { 
      position: relative; padding: 120px 0 80px; 
      background: linear-gradient(135deg, rgba(40, 46, 42, 0.65) 0%, rgba(40, 46, 42, 0.65) 100%), 
                  url('https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&q=80&w=1920') center/cover;
      color: #ffffff !important; 
    }
    .hero h1 { color: #ffffff !important; font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 800; line-height: 1.1; margin-bottom: 24px; max-width: 22ch; }
    .hero p { color: #ffffff !important; font-size: 1.25rem; max-width: 68ch; opacity: 0.95; margin-bottom: 0; line-height: 1.6; }

    .eyebrow { display: inline-flex; align-items: center; gap: 10px; padding: 8px 16px; border-radius: 999px; background: var(--avab-green); color: var(--avab-dark); font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 24px; }
    .eyebrow::before { content: ""; width: 8px; height: 8px; border-radius: 50%; background: #ffffff; box-shadow: 0 0 8px rgba(255, 255, 255, 0.6); }

    h2 { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 700; letter-spacing: -0.03em; margin-bottom: 16px; line-height: 1.15; }
    .lead-dark { font-size: 1.15rem; max-width: 68ch; color: var(--avab-dark-muted); margin-bottom: 20px; line-height: 1.6; }

    .two-col { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: start; }
    
    /* Summary List (Utmaningen) */
    .summary-list { display: grid; gap: 16px; list-style: none; margin-top: 62px; }
    .summary-list li { padding: 24px 20px; border-radius: var(--avab-radius-sm); background: var(--avab-white); box-shadow: var(--avab-shadow-sm); font-size: 1rem; color: var(--avab-dark-muted); border: 1px solid var(--avab-border); line-height: 1.5; }
    .summary-list strong { display: block; margin-bottom: 8px; color: var(--avab-dark); font-size: 1.15rem; line-height: 1.2; }

    /* Solutions Grid (De 4 rutorna) */
    .solutions-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 24px; margin-top: 24px; }
    .solution-card { 
      padding: 40px; border-radius: var(--avab-radius); background: var(--avab-white); 
      border: 1px solid var(--avab-border); box-shadow: var(--avab-shadow-sm); transition: var(--transition-smooth); 
      display: flex; flex-direction: column; position: relative; 
    }
    .solution-card:hover { transform: translateY(-8px); box-shadow: var(--avab-shadow-lg); border-color: var(--avab-green); }
    
    .solution-card-top { flex-grow: 1; display: flex; flex-direction: column; }
    .solution-card h3 { font-weight: 800; margin-bottom: 16px; font-size: 1.5rem; color: var(--avab-dark); line-height: 1.2; min-height: 3.6rem; display: flex; align-items: flex-start; }
    
    .solution-card .intro-text { margin-bottom: 24px; font-size: 1.05rem; color: var(--avab-dark-muted); line-height: 1.6; }

    .solution-card-bottom { margin-top: auto; }
    .solution-expandable { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.4s cubic-bezier(0.25, 1, 0.5, 1); }
    .solution-expand-inner { overflow: hidden; opacity: 0; transition: opacity 0.3s ease; }
    .solution-card:hover .solution-expandable { grid-template-rows: 1fr; }
    .solution-card:hover .solution-expand-inner { opacity: 1; }

    .hover-indicator { display: grid; grid-template-rows: 1fr; transition: grid-template-rows 0.4s ease, padding 0.4s ease; border-top: 1px solid var(--avab-border); padding-top: 20px; }
    .solution-card:hover .hover-indicator { grid-template-rows: 0fr; padding-top: 0; border-top-color: transparent; }
    .solution-card:hover .hover-indicator div { opacity: 0; }

    /* Länkar i rutor */
    .bullet-list { list-style: none; margin-top: 20px; }
    .bullet-list li { position: relative; padding-left: 28px; margin-bottom: 12px; font-weight: 500; font-size: 0.95rem; line-height: 1.5; color: var(--avab-dark-muted); }
    .bullet-list li::before { content: "✓"; position: absolute; left: 0; color: var(--avab-green); font-weight: 800; }
    .cat-link { color: var(--avab-dark); font-weight: 800; text-decoration: none; border-bottom: 2px solid var(--avab-green); transition: var(--transition-smooth); margin-right: 4px; }
    .cat-link:hover { background: var(--avab-green); color: #fff; }
    .kw-link { color: var(--avab-green); font-weight: 700; text-decoration: none; }
    .kw-link:hover { text-decoration: underline; }

    /* Synergy Flow Grid */
    .flow-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 20px; margin-top: 40px; }
    .flow-card { padding: 24px; border-radius: var(--avab-radius-sm); background: var(--avab-white); border: 1px solid var(--avab-border); box-shadow: var(--avab-shadow-sm); display: flex; flex-direction: column; }
    .flow-card strong { display: block; min-height: 3.2rem; margin-bottom: 12px; font-size: 1.05rem; color: var(--avab-green); line-height: 1.4; }
    .flow-card span { font-size: 0.95rem; color: var(--avab-dark-muted); line-height: 1.5; display: block; min-height: 4.5rem; }

    /* Referenser Grid */
    .ref-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(350px, 1fr)); gap: 24px; margin-top: 40px; align-items: stretch; }
    .ref-card { padding: 0; overflow: hidden; display: flex; flex-direction: column; height: 100%; background: var(--avab-white); border-radius: var(--avab-radius); border: 1px solid var(--avab-border); box-shadow: var(--avab-shadow-sm); transition: var(--transition-smooth); }
    .ref-card:hover { transform: translateY(-5px); box-shadow: var(--avab-shadow-lg); border-color: var(--avab-green); }
    .ref-card img { width: 100%; height: 240px; object-fit: cover; }
    .ref-content { padding: 32px; display: flex; flex-direction: column; flex-grow: 1; }
    .ref-content h3 { font-size: 1.4rem; margin-bottom: 12px; min-height: auto; } 
    .ref-content p { font-size: 1rem; color: var(--avab-dark-muted); line-height: 1.6; margin-bottom: 0; }

    /* FAQ & CTA */
    .faq-list { display: grid; gap: 16px; }
    .faq-item { padding-top: 16px; border-top: 1px solid var(--avab-border); }
    .faq-item:first-child { border-top: 0; padding-top: 0; }
    .faq-item h3 { font-size: 1.25rem; margin-bottom: 12px; font-weight: 700; color: var(--avab-dark); line-height: 1.15; }
    .faq-item p { color: var(--avab-dark-muted); line-height: 1.6; margin-bottom: 0; font-size: 1.1rem; }
    
    .cta-card { 
      background: linear-gradient(135deg, var(--avab-dark) 0%, #2A332C 50%, var(--avab-green) 100%); 
      color: var(--avab-white); padding: 48px; border-radius: var(--avab-radius); 
      display: flex; flex-direction: column; justify-content: center; position: relative; overflow: hidden;
    }
    
    /* NY: Exakt 62px offset på desktop för att CTA-rutan ska linjera med H2 i FAQ */
    @media (min-width: 1081px) {
      #faq .cta-card { margin-top: 62px; }
    }

    .cta-card h2, .cta-card p, .cta-card .eyebrow, .cta-card .guarantee-list, .cta-card .hero-actions { position: relative; z-index: 1; }
    .cta-card h2 { color: var(--avab-white); margin-bottom: 16px; }
    .cta-card p { color: var(--avab-white); line-height: 1.6; margin-bottom: 0; font-size: 1.1rem; }
    
    .guarantee-list { margin: 24px 0 0 0; padding: 0; list-style: none; display: flex; flex-direction: column; gap: 12px; }
    .guarantee-list li { display: flex; align-items: center; gap: 12px; font-weight: 600; color: var(--avab-white); font-size: 1rem; }
    .guarantee-list li::before { content: "✓"; display: flex; align-items: center; justify-content: center; width: 24px; height: 24px; border-radius: 50%; background: var(--avab-green); color: var(--avab-dark); font-size: 0.8rem; }

    /* Knappar */
    .button { display: inline-flex; align-items: center; justify-content: center; min-height: 56px; padding: 0 32px; border-radius: 999px; font-weight: 700; background: var(--avab-green); color: var(--avab-dark); text-decoration: none; transition: var(--transition-smooth); font-size: 1.05rem; }
    .button:hover { transform: translateY(-2px); box-shadow: 0 16px 32px var(--avab-green-glow); }
    
    .hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 16px; margin-top: 40px; }

    .cta-card .button-light { background: #fff; color: var(--avab-dark); }
    .cta-card .button-light:hover { background: #fff; box-shadow: 0 16px 32px rgba(0,0,0,0.2); }

    @media (max-width: 1080px) { 
      .two-col, .ref-grid { grid-template-columns: 1fr; } 
      .summary-list { margin-top: 24px; } 
    }
    @media (max-width: 768px) {
      .hero { padding: 100px 0 60px; } 
      .section { padding: 40px 0; } 
      .solution-card h3 { min-height: auto; } 
      .solution-expandable { grid-template-rows: 1fr; } .hover-indicator { display: none; } .solution-expand-inner { opacity: 1; }
      .flow-card strong, .flow-card span { min-height: auto; } 
    }
  </style>
</head>
<body>
  <SiteHeader />

  <header class="hero">
    <div class="container animate-in">
      <div class="eyebrow">Miljö: Skola & Utbildning</div>
      <h1>Tekniklösningar som lyfter pedagogiken och ökar tryggheten</h1>
      <p>Vi skapar intelligenta lärmiljöer där ljud, bild och säkerhet samverkar sömlöst. Från interaktiva klassrum till storskaliga system för hela skolområden.</p>
      
      <div class="hero-actions">
        <a class="button" href="/kontakt/">Boka kostnadsfri rådgivning</a>
      </div>
    </div>
  </header>

  <section class="fact-band" aria-label="Snabbfakta skola">
    <div class="fact-grid">
      <div class="fact"><span>Miljö</span><strong>Skola, aula och klassrum</strong></div>
      <div class="fact"><span>Ljud</span><strong>Tal, rastsignal och utrop</strong></div>
      <div class="fact"><span>Bild</span><strong>Projektor, skärm och signage</strong></div>
      <div class="fact"><span>Tillgänglighet</span><strong>Hörslinga och taluppfattbarhet</strong></div>
      <div class="fact"><span>Trygghet</span><strong>Inrymning och utrymning</strong></div>
      <div class="fact"><span>Leverans</span><strong>FFU till driftsatt skola</strong></div>
    </div>
  </section>

  <main>
    <section class="section" style="border-bottom: 1px solid var(--avab-border);">
      <div class="container two-col">
        <div class="animate-in">
          <div class="eyebrow">Verkligheten</div>
          <h2>Skolans komplexa teknikbehov</h2>
          <p class="lead-dark">Skolmiljön är en av de mest krävande ytorna att bygga teknik för. Dels ska pedagogiken stöttas av avancerade men lättanvända bild- och ljudsystem. Dels vilar ett enormt ansvar på skolan när det gäller trygghet, utrymning och säkerhet.</p>
          <p class="lead-dark">När man köper in klockor, högtalare och skärmar som isolerade system skapas stress för personalen. Vår lösning? Vi integrerar allt till ett enda pålitligt, digitalt ekosystem.</p>
        </div>

        <aside class="animate-in" style="animation-delay: 0.1s;">
          <ul class="summary-list">
            <li>
              <strong>Ljudnivån påverkar inlärningen</strong>
              Dålig taluppfattbarhet (STI) i klassrum och aulan leder bevisligen till sämre koncentration. Vi projekterar röstförstärkning och akustik som hjälper eleverna fokusera.
            </li>
            <li>
              <strong>Vikten av snabb inrymning (PDV)</strong>
              Vid en hotfull situation utomhus räcker inte en vanlig klocka. Moderna rastsignalsystem ger lärarna möjlighet att omedelbart kalla in alla via förinspelade instruktioner.
            </li>
            <li>
              <strong>Teknik ska stötta, inte störa</strong>
              En lärare ska inte behöva vara AV-tekniker. Genom smarta styrsystem säkerställer vi att lektionen kan börja med ett enda knapptryck.
            </li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section">
      <div class="container">
        
        <div class="section-header animate-in">
          <div class="eyebrow">Våra lösningar</div>
          <h2 style="margin-bottom: 16px;">Det digitala ekosystemet</h2>
          <p class="lead-dark">Här är våra vanligaste tekniklösningar paketerade för skolans vardag.</p>
        </div>

        <div class="solutions-grid">
          
          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Det digitala klassrummet</h3>
              <p class="intro-text">Enkelhet för läraren, fokus för eleven. Vi skapar miljöer där tekniken stöttar undervisningen utan att märkas.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div style="font-weight:800; color:var(--avab-green); text-transform:uppercase; font-size:0.75rem; letter-spacing:0.05em;">Utforska klassrummet ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/bild/" class="cat-link">Bild:</a> <a href="/bild/" class="kw-link">Projektor</a>, Touch & trådlös överföring</li>
                    <li><a href="/ljudsystem/" class="cat-link">Ljud:</a> <a href="/ljudsystem/" class="kw-link">Röstförstärkning</a> & högtalare</li>
                    <li><a href="/styrsystem/" class="cat-link">Integration:</a> Enkel kontroll för läraren</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Aula & Hörsal</h3>
              <p class="intro-text">Expertis för stora ytor och viktiga budskap. Vi garanterar att tekniken räcker till för både taluppfattbarhet och musik.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div style="font-weight:800; color:var(--avab-green); text-transform:uppercase; font-size:0.75rem; letter-spacing:0.05em;">Se aulateknik ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/ljudsystem/" class="cat-link">Ljud</a> & <a href="/losningar/horslingor/" class="cat-link">Hörslingor</a>: PA-system</li>
                    <li><a href="/bild/" class="cat-link">Bild:</a> Storbildsprojektion & infoskärmar</li>
                    <li><a href="/styrsystem/" class="cat-link">Styrning:</a> Crestron, DMX-ljus & KNX</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Rastsignal</h3>
              <p class="intro-text">Vårt mest populära system. Skapa struktur med digital precision, app-styrning och zonindelning.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div style="font-weight:800; color:var(--avab-green); text-transform:uppercase; font-size:0.75rem; letter-spacing:0.05em;">Se funktioner ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/rastsignal/" class="cat-link">Läs allt om Rastsignal:</a> Sidan visar alla tillbehör, inrymning och smarta app-funktioner.</li>
                  </ul>
                </div>
              </div>
            </div>
          </article>

          <article class="solution-card">
            <div class="solution-card-top">
              <h3>Trygghet & Utrymning</h3>
              <p class="intro-text">Integrerad säkerhet för personal och elever. Vi bygger system som räddar liv och ökar den allmänna tryggheten.</p>
            </div>
            <div class="solution-card-bottom">
              <div class="hover-indicator"><div style="font-weight:800; color:var(--avab-green); text-transform:uppercase; font-size:0.75rem; letter-spacing:0.05em;">Läs om säkerhet ↓</div></div>
              <div class="solution-expandable">
                <div class="solution-expand-inner">
                  <ul class="bullet-list">
                    <li><a href="/losningar/utrymningslarm/" class="cat-link">Utrymning</a> & <a href="/losningar/utrymningslarm/" class="cat-link">TUL:</a> Livräddande röst</li>
                    <li><a href="/kameraovervakning/" class="cat-link">Säkerhet</a> & <a href="/kameraovervakning/skola/" class="cat-link">Kameraövervakning skola</a></li>
                    <li><a href="/styrsystem/" class="cat-link">Integration:</a> Samverkan med larm & dörrar*</li>
                  </ul>
                  <p style="font-size: 0.8rem; margin-top: 15px; font-style: italic; color: var(--avab-dark-muted); line-height: 1.4;">*Vi projekterar integrationen och tillhandahåller partners för larm & lås.</p>
                </div>
              </div>
            </div>
          </article>

        </div>
        
        <div class="flow-grid animate-in">
          <div class="flow-card"><strong>Ljud → Taluppfattbarhet</strong><span>Bra högtalare i en aula räcker inte om talet studsar och ekar.</span></div>
          <div class="flow-card"><strong>Kamera → Säkerhet → Utrymning</strong><span>Upptäckt och guidning samverkar för total trygghet på skolgården.</span></div>
          <div class="flow-card"><strong>Styrsystem → Pedagogik</strong><span>Läraren styr mörkläggning, skärm och ljud från en enda touchpanel.</span></div>
        </div>

      </div>
    </section>

    <section class="section" style="border-top: 1px solid var(--avab-border);">
      <div class="container">
        <div class="eyebrow">Skolreferenser</div>
        <h2>Teknik som bevisats i verkligheten</h2>
        
        <div class="ref-grid animate-in">
          <article class="ref-card">
            <img src="https://images.unsplash.com/photo-1509062522246-3755977927d7?auto=format&fit=crop&q=80&w=800" alt="Minnebergsskolan aula och teknik">
            <div class="ref-content">
              <h3>Minnebergsskolan, Arvika</h3>
              <p>Nybyggd skola för 900 elever. Vi projekterade och installerade AV-teknik i 47 klassrum, 7 konferensrum, aula, 20 hörsalar och installerade 4 certifierade hörslingor.</p>
            </div>
          </article>

          <article class="ref-card">
            <img src="https://images.unsplash.com/photo-1580582932707-520aed937b7b?auto=format&fit=crop&q=80&w=800" alt="Stockfallets skola Karlstad rastsignal">
            <div class="ref-content">
              <h3>Stockfallets skola, Karlstad</h3>
              <p>Tidsstyrt rastsignalsystem i 2 zoner. Vädertåliga högtalare på skolfasad och sporthall som tillåter rektor och expedition att göra tydliga utrop över hela skolgården vid behov.</p>
            </div>
          </article>
        </div>
      </div>
    </section>

