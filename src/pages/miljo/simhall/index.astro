  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad behöver en simhall för AV-teknik?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En simhall behöver ofta ljudanläggning, fukttåliga högtalare, trådlösa mikrofoner, zonstyrning, hörslinga, infoskärmar, enkel styrning, STI-dokumentation och ibland talat utrymningslarm."
        }
      },
      {
        "@type": "Question",
        "name": "Varför är ljud i simhallar svårt?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kakel, glas, hårda ytor och vattenytor ger lång efterklang. Därför krävs rätt högtalartyp, riktning, zonindelning och inmätning för att tal ska uppfattas."
        }
      },
      {
        "@type": "Question",
        "name": "Kan elektriker installera efter AVAB:s underlag?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. AVAB kan projektera och driftsätta, medan elektriker installerar efter underlag. Vi kan också installera hela lösningen själva."
        }
      },
      {
        "@type": "Question",
        "name": "Vad kostar AV-teknik till en simhall?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Kostnaden beror på bassängytor, zoner, högtalarkrav, mikrofoner, styrning, fukt- och klorkrav, STI, talat utrymningslarm och installation. AVAB kan ge en tidig budgetnivå utifrån ritningar och funktionskrav."
        }
      },
      {
        "@type": "Question",
        "name": "När bör AV-tekniken komma in i byggprojektet?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "AV-tekniken bör komma in innan kabelvägar, teknikrum, rackplats, styrning, högtalarplacering och upphandlingskrav är låsta. I simhallar påverkar miljön materialval och montage extra mycket."
        }
      },
      {
        "@type": "Question",
        "name": "Hur skyddar man tekniken mot fukt och klor?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Genom att välja IP-klassade högtalare, korrosionsbeständiga material, rätt kabel och montage samt placera känslig elektronik i torra teknikrum."
        }
      },
      {
        "@type": "Question",
        "name": "Behöver en simhall hörslinga?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Publika ytor, läktare, reception och tävlingsmiljöer kan behöva planeras för hörslinga eller annan tillgänglighetslösning så att tal, utrop och tävlingsinformation når fler."
        }
      },
      {
        "@type": "Question",
        "name": "Kan ljud, ljus, spa och relax styras i samma system?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja. Ljud, zoner, mikrofoner, musik, infoskärmar, RGB-belysning över DMX, KNX-funktioner, bastustyrning, temperatur och mätvärden kan samlas i enkel styrning för reception, badvakter och driftpersonal."
        }
      }
    ]
  }
  </script>

