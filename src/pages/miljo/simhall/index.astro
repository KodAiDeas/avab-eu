  <link rel="preconnect" href="https://images.unsplash.com" crossorigin>
  <link rel="preconnect" href="https://avab.eu" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Preload av hero-bilden (LCP) -->
  <link rel="preload" as="image" fetchpriority="high"
    href="/assets/avab-referens-saffle-simhall-1350x900.webp">

  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Sidspecifika komponenter (resten finns i importerad avab.css) -->
  <style>
    /* ---- Lösningskort (grön ram, accentkant) ---- */
    .solution-card {
      border: 2px solid rgba(143, 192, 37, 0.62);
      box-shadow: 0 18px 42px rgba(143, 192, 37, 0.12);
      position: relative;
      overflow: hidden;
    }
    .solution-card::before {
      content: "";
      position: absolute;
      inset: 0 auto 0 0;
      width: 8px;
      background: var(--avab-green);
    }
    .solution-card h3,
    .solution-card .bullet-list { position: relative; z-index: 1; }

    /* ---- Inre länk i bild-/referenskort ("Läs om … →") ---- */
    .ref-content a {
      margin-top: auto;
      font-weight: 800;
      color: var(--avab-dark);
    }
    .ref-content a:hover { color: var(--avab-green); }
    .ref-content a::after { content: " →"; color: var(--avab-green); }
    /* Mindre bildhöjd för teknik-korten */
    .ref-card.service-card img { height: 190px; }

    /* ---- Budget-/kalkylband (mitt på sidan) ---- */
    .calculator-band {
      margin-top: 30px;
      padding: 28px;
      border-radius: var(--avab-radius-sm);
      background:
        radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 34%),
        linear-gradient(135deg, #425c19 0%, #6f9f1f 52%, var(--avab-green) 100%);
      border: 1px solid rgba(255, 255, 255, 0.18);
      box-shadow: 0 18px 34px rgba(40, 46, 42, 0.18);
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 20px;
      align-items: center;
    }
    .calculator-band h3 { color: #fff; font-size: 1.35rem; margin-bottom: 6px; }
    .calculator-band p { margin-bottom: 0; color: rgba(255, 255, 255, 0.9); font-size: 1rem; max-width: 760px; }
    .calculator-band .button {
      background: #fff;
      color: var(--avab-dark);
      box-shadow: 0 14px 28px rgba(40, 46, 42, 0.18);
    }
    .calculator-band .button:hover { background: var(--avab-dark); color: #fff; }

    /* ---- FAQ: vänsterställd rubrik + tvåkolumnslayout ---- */
    .faq-heading { max-width: 760px; margin: 0 0 30px; text-align: left; }
    .faq-heading .eyebrow { margin-left: 0; margin-right: 0; }
    .faq-heading h2 { margin-bottom: 12px; max-width: 680px; }
    .faq-heading p { color: var(--avab-dark-muted); margin-bottom: 0; max-width: 760px; }

    .compact-faq {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      column-gap: 28px;
      row-gap: 0;
      max-width: 1060px;
      margin: 0 auto;
    }
    .compact-faq details.faq-item { padding: 20px 0; }
    .compact-faq summary { font-size: 1.05rem; }
    .compact-faq details.faq-item p { font-size: 0.98rem; }
    /* Översta raden (de två första) får en topplinje */
    .compact-faq details.faq-item:nth-child(1),
    .compact-faq details.faq-item:nth-child(2) { border-top: 1px solid var(--avab-border); }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 768px) {
      .calculator-band { grid-template-columns: 1fr; padding: 24px; }
      .compact-faq { grid-template-columns: 1fr; }
      .compact-faq details.faq-item:nth-child(2) { border-top: none; }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
        <li><a href="https://www.avab.eu/">Start</a></li>
        <li><a href="https://www.avab.eu/#miljoer">Miljöer</a></li>
        <li><span aria-current="page">Simhall &amp; badhus</span></li>
      </ol>
    </div>
  </nav>

  <section class="hero" style="--hero-image:url('/assets/avab-referens-saffle-simhall-1350x900.webp');">
    <div class="avab-container">
      <div class="hero-inner animate-in">
        <div class="eyebrow">Simhall &amp; badhus</div>

        <h1>Komplett AV-lösning för simhallar</h1>

        <p class="lead">
          Tydligt tal, zonstyrt ljud, hörslinga, infoskärmar, smart styrning och fukttålig teknik för simhallar, badhus, relax, gym och publika badanläggningar.
          För kommuner, byggbolag, elektriker och upphandlare som vill få rätt teknik från projektering till färdig drift.
        </p>

        <div class="hero-bottom">
          <div class="hero-actions">
            <a class="button button-primary" href="/kontakt/">Skicka ritningar eller boka genomgång</a>
            <a class="button button-secondary" href="/kontakt/">Få budgetnivå tidigt</a>
            <a class="button button-quiet" href="#far-du">Se vad som ingår</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <div class="procurement-strip">
    <div class="avab-container procurement-container">
      <span class="procurement-item">Tydligt tal</span>
      <span class="procurement-item">Fukttålig teknik</span>
      <span class="procurement-item">Smart styrning</span>
      <span class="procurement-item">Upphandlingsklart underlag</span>
    </div>
  </div>


  <section class="fact-band" aria-label="Snabbfakta simhall">
    <div class="fact-grid">
      <div class="fact"><span>Miljö</span><strong>Simhall &amp; badhus</strong></div>
      <div class="fact"><span>Ljud</span><strong>Tal, utrop och musik</strong></div>
      <div class="fact"><span>Material</span><strong>IP-klassat och fukttåligt</strong></div>
      <div class="fact"><span>Tillgänglighet</span><strong>Hörslinga och STI</strong></div>
      <div class="fact"><span>Underlag</span><strong>FFU, AB 04 och ABT 06</strong></div>
      <div class="fact"><span>Leverans</span><strong>Projektering till drift</strong></div>
    </div>
  </section>


  <main id="main">
    <section class="section section--light" id="far-du">
      <div class="avab-container">
        <div class="section-heading">
          <div>
            <div class="eyebrow">Det här får du</div>
            <h2>Tydligt tal, fukttålig teknik och smart styrning</h2>
            <p class="lead-dark">En simhall ska fungera för simskola, motionssim, tävling, vattengympa, relax, gym, publik och drift. AVAB bygger tekniken som ett sammanhängande system.</p>
          </div>
        </div>

        <div class="value-grid">
          <article class="value-card">
            <span class="value-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 5 6 9H2v6h4l5 4z"/><path d="M15.54 8.46a5 5 0 0 1 0 7.07"/><path d="M19.07 4.93a10 10 0 0 1 0 14.14"/></svg></span>
            <h3>Tydligt tal</h3>
            <p>Instruktörer, speakerljud och utrop som hörs och förstås.</p>
          </article>
          <article class="value-card">
            <span class="value-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2.5S5.5 9.5 5.5 14a6.5 6.5 0 0 0 13 0c0-4.5-6.5-11.5-6.5-11.5z"/></svg></span>
            <h3>Fukttåligt</h3>
            <p>Högtalare, kabel, montage och materialval för klor och fukt.</p>
          </article>
          <article class="value-card">
            <span class="value-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg></span>
            <h3>Zoner</h3>
            <p>Bassäng, läktare, relax, gym och omklädning med rätt ljudnivå.</p>
          </article>
          <article class="value-card">
            <span class="value-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" y1="21" x2="4" y2="14"/><line x1="4" y1="10" x2="4" y2="3"/><line x1="12" y1="21" x2="12" y2="12"/><line x1="12" y1="8" x2="12" y2="3"/><line x1="20" y1="21" x2="20" y2="16"/><line x1="20" y1="12" x2="20" y2="3"/><line x1="1" y1="14" x2="7" y2="14"/><line x1="9" y1="8" x2="15" y2="8"/><line x1="17" y1="16" x2="23" y2="16"/></svg></span>
            <h3>Styrning</h3>
            <p>Crestron, KNX, DMX och scenarion för personal och drift.</p>
          </article>
          <article class="value-card">
            <span class="value-icon" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><rect x="9" y="3" width="6" height="4" rx="1"/><path d="m9 14 2 2 4-4"/></svg></span>
            <h3>Upphandlingsklart</h3>
            <p>FFU, dokumentation, inmätning och tydlig gränsdragning.</p>
          </article>
        </div>

        <div class="calculator-band">
          <div>
            <h3>Vill du få budgetnivå tidigt?</h3>
            <p>Skicka ritningar eller funktionskrav så hjälper vi er att bedöma ljud, zoner, hörslinga, styrning, fukttåligt montage, STI och eventuellt talat utrymningslarm.</p>
          </div>
          <a class="button button-primary" href="/kontakt/">Boka budgetgenomgång</a>
        </div>
      </div>
    </section>

    <section class="section" id="problem">
      <div class="avab-container two-col">
        <div>
          <div class="eyebrow">Lösning</div>
          <h2>Simhallar kräver mer än vanliga ljudsystem</h2>
          <p>I många badhus hörs ljudet, men talet går ändå inte att uppfatta. Orsaken är ofta kakel, glas, stora vattenytor, högt tak, publikljud och lång efterklang.</p>
          <p>Samtidigt bryter fukt, klor och temperaturväxlingar ner standardteknik. Därför behöver simhallsteknik projekteras för både taluppfattbarhet, materialhållbarhet, service och daglig användning.</p>
        </div>

        <aside class="card solution-card">
          <h3>Därför projekterar vi systemet som en helhet</h3>
          <ul class="bullet-list">
            <li>Ljudanläggning och högtalarplacering för taluppfattbarhet.</li>
            <li>IP-klassade högtalare och korrosionsanpassat montage.</li>
            <li>Zoner för bassäng, läktare, relax, spa, gym och omklädning.</li>
            <li>Trådlösa mikrofoner, fukttåliga headset, musik och utrop.</li>
            <li>Hörslinga, STI, talat utrymningslarm, dokumentation och driftunderlag.</li>
            <li>Crestron, KNX, DMX, infoskärmar, bastustyrning, temperatur och mätvärden.</li>
          </ul>
        </aside>
      </div>
    </section>

    <section class="section" id="teknik">
      <div class="avab-container">
        <div class="section-heading">
          <div>
            <div class="eyebrow">Teknik i simhall</div>
            <h2>Fler system, men en enkel vardag</h2>
            <p class="lead-dark">Simhallar behöver ofta mer än ljud. Rätt lösning binder ihop tävling, tillgänglighet, spa, relax, belysning, information och drift i samma tydliga användarflöde.</p>
          </div>
        </div>

        <div class="grid-3">
          <article class="ref-card service-card">
            <img src="/assets/saffle simhall tävling simhall 1200x900.webp" alt="Simhall med publik läktare tävling och tillgänglighet" width="900" height="600" loading="lazy" decoding="async">
            <div class="ref-content">
              <h3>Tävling, publik och hörslinga</h3>
              <p>Vid tävlingar, upprop och prisutdelningar behöver information nå alla. Vi planerar taluppfattbarhet, speakerljud, läktare, hörslinga och tillgänglighet från början.</p>
              <a href="/referenser/saffle-simhall/">Läs mer</a>
            </div>
          </article>

          <article class="ref-card service-card">
            <img src="/assets/hundfjallshotellet_spa.webp" alt="Spa relax RGB-belysning och smart styrning i badhus" width="900" height="600" loading="lazy" decoding="async">
            <div class="ref-content">
              <h3>Spa, relax och ljus</h3>
              <p>Crestron, KNX och DMX kan styra ljudzoner, RGB-belysning under vatten, scenarion i relax, start av bastu, temperatur och andra funktioner som personalen ska hantera enkelt.</p>
              <a href="/referenser/saffle-simhall/">Se styrning i referensprojekt</a>
            </div>
