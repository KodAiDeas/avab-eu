    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "FAQPage",
        "@id": "https://www.avab.eu/tjanster/taluppfattbarhet/#faq",
        "mainEntity": [
          {
            "@type": "Question",
            "name": "Vad betyder taluppfattbarhet?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Taluppfattbarhet beskriver hur lätt det är att förstå tal i en lokal. Det handlar inte bara om ljudnivå, utan om tydlighet, jämnhet, akustik och hur ljudsystemet samverkar med rummet."
            }
          },
          {
            "@type": "Question",
            "name": "Varför hjälper det inte alltid att höja volymen?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Om lokalen har mycket efterklang, reflexer eller bakgrundsbuller kan högre volym göra talet ännu mer otydligt. Då behövs bättre högtalarplacering, riktning, akustik eller systeminställningar."
            }
          },
          {
            "@type": "Question",
            "name": "Vad är STI och STIPA?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "STI och STIPA är metoder för att bedöma hur tydligt tal överförs från ljudsystemet till lyssnaren. De används när man vill mäta och dokumentera taltydlighet i en lokal."
            }
          },
          {
            "@type": "Question",
            "name": "Kan man förbättra taluppfattbarheten utan att byta hela ljudsystemet?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Ja, ibland räcker det med injustering, omriktning av högtalare, bättre zonindelning eller kompletterande högtalare. I andra fall behöver ljudsystemet bytas eller kombineras med akustiska åtgärder."
            }
          },
          {
            "@type": "Question",
            "name": "Hur hänger taluppfattbarhet ihop med hörslinga?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Taluppfattbarhet handlar om att tal ska vara tydligt i lokalen. Hörslinga hjälper personer med hörapparat att ta emot ljudet direkt, utan lika mycket störande bakgrundsljud och efterklang. Därför är hörslinga ofta en viktig del av tillgängligt ljud."
            }
          },
          {
            "@type": "Question",
            "name": "När passar Auracast bättre än hörslinga?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Auracast kan passa i lokaler där det är svårt att installera traditionell hörslinga, till exempel kyrkor, kulturmiljöer eller konferensanläggningar. Valet beror på lokalens förutsättningar, användning och vilka besökare som ska kunna ta del av ljudet."
            }
          },
          {
            "@type": "Question",
            "name": "Vilka lokaler behöver bra taluppfattbarhet?",
            "acceptedAnswer": {
              "@type": "Answer",
              "text": "Alla lokaler där människor ska kunna uppfatta tal, instruktioner, utrop eller säkerhetsmeddelanden behöver bra taluppfattbarhet. Det gäller till exempel skolor, sporthallar, konferensrum, kyrkor, simhallar, industrier och publika lokaler."
            }
          }
        ]
      }
    </script>
