        "https://www.facebook.com/avab"
      ],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Skraggevägen 4",
        "postalCode": "663 41",
        "addressLocality": "Hammarö",
        "addressRegion": "Värmland",
        "addressCountry": "SE"
      }
    },
