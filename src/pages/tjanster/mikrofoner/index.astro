  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vilken mikrofon passar bäst i sporthall?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ofta passar trådlösa handmikrofoner bäst för speaker och allmänt tal. Vid instruktion eller aktivitet kan headset vara bättre. Viktigast är stabil räckvidd, bra antennplacering och rätt ljudsystem."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är skillnaden mellan handmikrofon och headset?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Handmikrofon är enkel och flexibel, men måste hållas rätt. Headset ger fria händer och jämnare avstånd till munnen, men kräver bättre passform och mer skötsel."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är en ficksändare?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En ficksändare är den trådlösa sändare som bärs på kroppen och kopplas till headset eller mygga. Den skickar ljudet till mottagaren i ljudsystemet."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är SpeechLine?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "SpeechLine Digital Wireless är Sennheisers digitala trådlösa system för tal, presentation och utbildning. Det passar bra i skolor, föreläsningssalar, företag och konferensmiljöer där enkel drift är viktig."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är en takmikrofon?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "En takmikrofon är en mikrofon, ofta med flera kapslar och beamforming, som monteras i eller vid taket. Den används ofta i konferensrum och utbildningsrum för att fånga tal utan mikrofoner på bordet."
        }
      },
      {
        "@type": "Question",
        "name": "Vad är skillnaden mellan dynamisk mikrofon och kondensatormikrofon?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Dynamiska mikrofoner är robusta och vanliga för tal, scen och handhållen användning. Kondensatormikrofoner är känsligare och används ofta i takmikrofoner, headset, myggor, svanhalsar, studio och konferensrum."
        }
      },
      {
        "@type": "Question",
        "name": "Behövs antennplanering för trådlösa mikrofoner?",
        "acceptedAnswer": {
          "@type": "Answer",
          "text": "Ja, särskilt när flera mikrofoner används samtidigt eller när lokalen är stor. Antennplacering, kabeltyp, frekvenser och mottagare påverkar stabiliteten mycket."
        }
      }
    ]
  }
  </script>

