              alt="Tillgängligt ljud i en publik lokal där fler kan delta på samma villkor"
              width="900" height="600" loading="lazy" decoding="async">
          </div>
          <p class="image-caption">Tillgängligt ljud gör att fler kan delta på samma villkor i möten, undervisning och evenemang.</p>
        </aside>
      </div>

      <div class="avab-container">
        <div class="calculator-band">
          <div>
