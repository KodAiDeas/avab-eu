  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Delad designsystem-CSS -->
  <!-- Sidspecifika komponenter -->
  <style>
    /* ---- AEO-svarsruta (snippet-box) ---- */
    .snippet-box {
      padding: 28px;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      border-left: 8px solid var(--avab-green);
      box-shadow: var(--avab-shadow-sm);
      margin-top: 28px;
    }
    .snippet-box strong { display: block; font-size: 1.1rem; margin-bottom: 8px; color: var(--avab-dark); }
    .snippet-box p { margin-bottom: 0; font-size: 1.05rem; }

    /* ---- Definitionskort (tagg + titel + text) ---- */
    .definition-grid { display: grid; grid-template-columns: repeat(3, minmax(0, 1fr)); gap: 18px; margin-top: 32px; }
    .definition-card { background: var(--avab-white); border: 1px solid var(--avab-border); border-radius: var(--avab-radius-sm); padding: 24px; box-shadow: var(--avab-shadow-sm); }
    .definition-card .tag { display: inline-flex; margin-bottom: 14px; padding: 6px 12px; border-radius: 999px; background: var(--avab-green); color: var(--avab-dark); font-weight: 800; font-size: 0.78rem; letter-spacing: 0.04em; text-transform: uppercase; }
    .definition-card h3 { font-size: 1.15rem; margin-bottom: 8px; }
    .definition-card p { font-size: 1rem; margin-bottom: 0; color: var(--avab-dark-muted); }

    /* ---- PLS/SLS-jämförelsekort ---- */
    .compare-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 40px; }
    .compare-card { background: var(--avab-white); border: 1px solid var(--avab-border); border-radius: var(--avab-radius); overflow: hidden; box-shadow: var(--avab-shadow-sm); }
    .compare-card-header { padding: 32px 32px 18px; }
    .compare-card-header .tag { display: inline-flex; background: var(--avab-green); color: var(--avab-dark); border-radius: 999px; padding: 6px 12px; font-weight: 800; font-size: 0.8rem; margin-bottom: 16px; }
    .compare-card-body { padding: 0 32px 32px; }

    /* ---- Mini-tabell (krav/koder, jämförelse) ---- */
    .mini-table { display: grid; gap: 10px; margin-top: 20px; }
    .mini-row { display: grid; grid-template-columns: 150px 1fr; gap: 14px; border-top: 1px solid var(--avab-border); padding-top: 10px; font-size: 0.98rem; color: var(--avab-dark-muted); }
    .mini-row strong { color: var(--avab-dark); }

    /* ---- Mörkt läckage-/sekretessband ---- */
    .leakage-band { background: linear-gradient(135deg, var(--avab-dark), #1f241f); color: #fff; border-radius: var(--avab-radius); padding: 48px; display: grid; grid-template-columns: 1fr 1fr; gap: 40px; align-items: center; box-shadow: var(--avab-shadow-lg); border-left: 8px solid var(--avab-green); }
    .leakage-band h2, .leakage-band h3 { color: #fff; }
    .leakage-band p { color: rgba(255, 255, 255, 0.86); }
    .leakage-band .snippet-box { background: rgba(255, 255, 255, 0.08); border-color: rgba(255, 255, 255, 0.18); border-left-color: var(--avab-green); }
    .leakage-band .snippet-box strong { color: #fff; }
    .leakage-band .snippet-box p { color: rgba(255, 255, 255, 0.86); }

    /* ---- Budget-/kalkylband ---- */
    .calculator-band {
      margin-top: 30px;
      padding: 28px;
      border-radius: var(--avab-radius-sm);
      background:
        radial-gradient(circle at top left, rgba(255, 255, 255, 0.18), transparent 34%),
        linear-gradient(135deg, #425c19 0%, #6f9f1f 52%, var(--avab-green) 100%);
      border: 1px solid rgba(255, 255, 255, 0.18);
      box-shadow: 0 18px 34px rgba(40, 46, 42, 0.18);
      display: grid;
      grid-template-columns: minmax(0, 1fr) auto;
      gap: 20px;
      align-items: center;
    }
    .calculator-band h3 { color: #fff; font-size: 1.35rem; margin-bottom: 6px; }
    .calculator-band p { margin-bottom: 0; color: rgba(255, 255, 255, 0.9); font-size: 1rem; max-width: 760px; }
    .calculator-band .button { background: #fff; color: var(--avab-dark); box-shadow: 0 14px 28px rgba(40, 46, 42, 0.18); }
    .calculator-band .button:hover { background: var(--avab-dark); color: #fff; }

    /* ---- Prisindikator ---- */
    .price-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; margin-top: 48px; }
    .price-card { background: var(--avab-white); border: 1px solid var(--avab-border); border-radius: var(--avab-radius); padding: 36px 32px; box-shadow: var(--avab-shadow-sm); text-align: center; display: flex; flex-direction: column; min-height: 340px; }
    .price-card.featured { border: 2px solid var(--avab-green); box-shadow: var(--avab-shadow-lg); }
    .price-label { display: inline-flex; align-items: center; justify-content: center; gap: 8px; align-self: center; padding: 8px 18px; border-radius: 999px; background: var(--avab-light); border: 1px solid var(--avab-border); color: var(--avab-dark); font-size: 0.85rem; font-weight: 800; text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 28px; }
    .price-label.green { background: var(--avab-green); border-color: var(--avab-green); }
    .price-card .price { font-size: clamp(2.1rem, 4vw, 2.8rem); line-height: 1; color: var(--avab-green); font-weight: 800; margin-bottom: 22px; }
    .price-card p { font-size: 1.05rem; margin-bottom: 0; }
    .price-note { margin-top: 40px; padding: 28px; border-radius: var(--avab-radius-sm); background: var(--avab-green-soft); border-left: 4px solid var(--avab-green); max-width: 820px; }
    .price-note strong { display: block; margin-bottom: 10px; color: var(--avab-dark); }
    .price-note p { margin-bottom: 0; }

    /* ---- Interna länkpiller (miljöer/tjänster) ---- */
    .link-pills { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
    .link-pills a { display: inline-flex; align-items: center; background: var(--avab-white); color: var(--avab-dark); border: 1px solid var(--avab-border); font-weight: 700; padding: 14px 24px; border-radius: 999px; font-size: 1.05rem; transition: var(--transition-smooth); box-shadow: var(--avab-shadow-sm); }
    .link-pills a:hover { background: var(--avab-green); border-color: var(--avab-green); transform: translateY(-2px); box-shadow: 0 8px 16px rgba(143, 192, 37, 0.2); }

    /* ---- Klickbara miljö-rutor (Vanliga miljöer) ---- */
    .miljo-links { display: grid; gap: 12px; margin-top: 4px; }
    .miljo-link { display: block; position: relative; padding: 18px 44px 18px 20px; border: 1px solid var(--avab-border); border-radius: var(--avab-radius-sm); background: var(--avab-white); box-shadow: var(--avab-shadow-sm); color: var(--avab-dark); transition: var(--transition-smooth); }
    .miljo-link:hover, .miljo-link:focus-visible { border-color: var(--avab-green); transform: translateY(-3px); box-shadow: var(--avab-shadow-lg); }
    .miljo-link strong { display: block; margin-bottom: 2px; font-size: 1.05rem; }
    .miljo-link span { display: block; color: var(--avab-dark-muted); font-size: 0.96rem; font-weight: 500; line-height: 1.5; }
    .miljo-link::after { content: "→"; position: absolute; right: 18px; top: 18px; color: var(--avab-green); font-weight: 800; transition: var(--transition-smooth); }
    .miljo-link:hover::after { transform: translateX(4px); }

    /* ---- Grönt CTA-kort i miljö-griden ---- */
    a.definition-card { transition: var(--transition-smooth); }
    .definition-card.cta-green { background: var(--avab-green); border-color: var(--avab-green); color: var(--avab-dark); box-shadow: var(--avab-shadow-lg); }
    .definition-card.cta-green h3 { color: var(--avab-dark); }
    .definition-card.cta-green p { color: rgba(40, 46, 42, 0.85); }
    .definition-card.cta-green .tag { background: var(--avab-dark); color: #fff; }
    .definition-card.cta-green .go { display: inline-flex; align-items: center; gap: 8px; margin-top: 14px; font-weight: 800; color: var(--avab-dark); }
    .definition-card.cta-green .go::after { content: "→"; transition: var(--transition-smooth); }
    a.definition-card.cta-green:hover { transform: translateY(-4px); box-shadow: 0 22px 44px var(--avab-green-glow); }
    a.definition-card.cta-green:hover .go::after { transform: translateX(4px); }

    /* ---- Bildplatshållare (endast för diagram/illustrationer som ska bli AVAB:s egna) ---- */
    .image-placeholder { min-height: 320px; width: 100%; border-radius: var(--avab-radius-sm); border: 2px dashed rgba(40, 46, 42, 0.22); background: linear-gradient(135deg, #f7f8f7 0%, #e9eae9 100%); display: flex; align-items: center; justify-content: center; text-align: center; padding: 32px; color: var(--avab-dark-muted); font-weight: 800; }
    .image-placeholder span { display: block; max-width: 36ch; }
    .image-caption { font-size: 0.92rem; margin-top: 12px; color: var(--avab-dark-muted); }

    @media (max-width: 1024px) {
      .compare-grid { grid-template-columns: 1fr; }
      .definition-grid { grid-template-columns: 1fr 1fr; }
      .leakage-band { grid-template-columns: 1fr; gap: 40px; }
    }
    @media (max-width: 768px) {
      .definition-grid { grid-template-columns: 1fr; }
      .calculator-band { grid-template-columns: 1fr; padding: 24px; }
      .price-grid { grid-template-columns: 1fr; }
      .mini-row { grid-template-columns: 1fr; gap: 2px; }
      .leakage-band { padding: 40px 24px; }
    }
  </style>
</head>
<body>
  <SiteHeader />

  <nav class="breadcrumbs" aria-label="Brödsmulor">
    <div class="avab-container">
      <ol>
