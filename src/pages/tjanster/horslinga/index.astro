        "CPV 32342410"
      ]
    },
    "areaServed": "Sverige",
    "audience": {
      "@type": "Audience",
      "audienceType": "Elektriker, projektörer, upphandlare, fastighetsägare, skolor, kommuner, kyrkor, vårdverksamheter, hotell, konferensanläggningar och publika lokaler"
    },
    "serviceType": [
      "Hörslinga",
      "Teleslinga och induktiv hörslinga",
      "PLS perimeterslinga",
      "SLS lågläckande hörslinga",
      "Diskslinga och receptionsslinga",
      "Auracast och Bluetooth LE Audio",
      "Projektering av tillgängligt ljud",
      "Mätning enligt SS-EN IEC 60118-4",
      "Certifiering och dokumentation av hörslinga",
      "Tillgänglighet och taluppfattbarhet"
    ],
    "description": "AVAB projekterar, installerar, mäter och certifierar hörslingor, teleslingor, induktiva hörslingor, diskslingor, PLS, SLS och Auracast-lösningar för skolor, kyrkor, sporthallar, vård, konferens och publika lokaler i hela Sverige."
  }
  </script>

  <!-- JSON-LD 2: FAQPage (svaren matchar den synliga FAQ:n ord för ord) -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "Vad är en hörslinga?",
        "acceptedAnswer": { "@type": "Answer", "text": "En hörslinga är ett system som skickar ljud trådlöst till hörapparater och cochleaimplantat med telespole. Ljudet överförs via ett magnetfält från en kabel eller folie som installeras i lokalen." }
      },
      {
        "@type": "Question",
        "name": "Vad är skillnaden mellan hörslinga och teleslinga?",
        "acceptedAnswer": { "@type": "Answer", "text": "Hörslinga, teleslinga, induktionsslinga och induktiv hörslinga är vanliga ord för samma grundteknik: ljud skickas via magnetfält till en mottagares telespole eller T-läge." }
      },
      {
        "@type": "Question",
        "name": "Måste alla publika lokaler ha hörslinga?",
        "acceptedAnswer": { "@type": "Answer", "text": "Vid nybyggnation och större renovering ska tillgänglig ljudöverföring hanteras i publika lokaler och samlingslokaler. Exakt krav och teknisk lösning beror på lokalen, användningen och projektets regelverk." }
      },
      {
        "@type": "Question",
        "name": "Vad är skillnaden mellan PLS och SLS?",
        "acceptedAnswer": { "@type": "Answer", "text": "PLS är en enklare perimeterslinga som ofta passar mindre rum. SLS är en mer avancerad lösning för större eller mer krävande lokaler där man behöver jämnare täckning och bättre kontroll på läckage." }
      },
      {
        "@type": "Question",
        "name": "Läcker en hörslinga utanför rummet?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ja, magnetfältet från en hörslinga kan sprida sig utanför rummet. Med SLS och rätt projektering kan läckaget begränsas betydligt bättre än med en enkel perimeterslinga." }
      },
      {
        "@type": "Question",
        "name": "Vad är Auracast?",
        "acceptedAnswer": { "@type": "Answer", "text": "Auracast är en Bluetooth LE Audio-baserad teknik som kan sända ljud trådlöst till många kompatibla mottagare samtidigt, till exempel vissa moderna hörapparater, hörlurar och andra enheter." }
      },
      {
        "@type": "Question",
        "name": "Ersätter Auracast hörslinga?",
        "acceptedAnswer": { "@type": "Answer", "text": "Inte alltid. Auracast är ett intressant komplement, men alla användare har inte kompatibla mottagare. Hörslinga är fortfarande en robust lösning för många hörapparater och cochleaimplantat med telespole." }
      },
      {
        "@type": "Question",
        "name": "Varför är SLS bättre än Auracast i en sporthall?",
        "acceptedAnswer": { "@type": "Answer", "text": "I en sporthall rör sig användarna ofta mycket. Då är en fast installerad SLS-lösning normalt bättre än en lösning där användaren behöver bära mottagare och halsslinga under aktivitet." }
      },
      {
        "@type": "Question",
        "name": "Vad behöver vara klart innan SLS installeras på betonggolv?",
        "acceptedAnswer": { "@type": "Answer", "text": "Betonggolvet behöver vara väl rengjort så att tejp, slingfolie och skyddstejp fäster ordentligt. Bäst är att golvet inte används innan det täcks med flytspackel, matta, trägolv eller annat ytskikt." }
      },
      {
        "@type": "Question",
        "name": "Vad är en diskslinga?",
        "acceptedAnswer": { "@type": "Answer", "text": "En diskslinga är en mindre och avgränsad hörslinga för reception, kassa, informationsdisk eller biljettlucka som skickar samtalet direkt till besökarens telespole." }
      },
      {
        "@type": "Question",
        "name": "När passar en portabel hörslinga?",
        "acceptedAnswer": { "@type": "Answer", "text": "En portabel hörslinga passar tillfälliga möten, konferenser, utbildningar och event där en fast installation saknas." }
      },
      {
        "@type": "Question",
        "name": "Kan en elektriker installera hörslingan?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ja. AVAB kan projektera slingan, leverera ritningar och materialunderlag och stötta den lokala elektrikern. Systemval, injustering, mätning och certifiering bör utföras av en aktör med erfarenhet av hörslingor." }
      },
      {
        "@type": "Question",
        "name": "När behöver AVAB komma in i projektet?",
        "acceptedAnswer": { "@type": "Answer", "text": "Helst innan golv, kabelvägar, rackplats och upphandlingskrav är låsta. En golvförlagd slinga behöver projekteras och samordnas tidigt." }
      },
      {
        "@type": "Question",
        "name": "Behöver en hörslinga märkas med skylt?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ja. Publika lokaler med hörslinga bör märkas med den internationella hörslingesymbolen så att besökare ser att de kan använda T-läge på sin hörapparat eller sitt cochleaimplantat." }
      },
      {
        "@type": "Question",
        "name": "Behöver en hörslinga mätas?",
        "acceptedAnswer": { "@type": "Answer", "text": "Ja. En hörslinga bör mätas och justeras så att fältstyrka, jämnhet, frekvensåtergivning och störnivåer fungerar i den verkliga lokalen." }
      },
      {
        "@type": "Question",
        "name": "Vilka standarder och koder är relevanta vid upphandling?",
        "acceptedAnswer": { "@type": "Answer", "text": "Hörslingor mäts mot SS-EN IEC 60118-4. I tekniska beskrivningar förekommer AMA EL-koderna 64.ECB/3 och 64.ECB/31, och i offentlig upphandling CPV-koderna 51313000 och 32342410. Kontrollera alltid mot aktuell AMA-version och projektets handlingar." }
      }
    ]
  }
  </script>

  <!-- JSON-LD 3: BreadcrumbList -->
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
