      "url": "https://avab.eu/",
      "logo": "https://avab.eu/wp-content/uploads/logo.png",
      "telephone": "+46-54-820-20-80",
      "email": "info@avab.eu",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Skraggevägen 4",
        "postalCode": "663 41",
        "addressLocality": "Hammarö",
        "addressRegion": "Värmland",
        "addressCountry": "SE"
      },
      "knowsAbout": [
        "Hörslinga",
        "Teleslinga",
        "Induktiv hörslinga",
        "SLS hörslinga",
        "PLS hörslinga",
        "Diskslinga",
        "Auracast",
