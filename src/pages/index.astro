      "@type": "SpeakableSpecification",
      "cssSelector": ["h1", ".hero .lead", ".faq-list"]
    }
  }
  </script>

  <link rel="preconnect" href="https://images.unsplash.com" crossorigin>
  <link rel="preconnect" href="https://avab.eu" crossorigin>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

  <!-- Preload av hero-bilden (LCP) -->
  <link rel="preload" as="image" fetchpriority="high"
    href={heroImage}>

  <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  <!-- Delad designsystem-CSS -->
  <link rel="stylesheet" href="avab.css">

  <!-- Sidspecifika komponenter (resten finns i avab.css) -->
  <style>
    /* ---- Expertområden (bildkort) ---- */
    .solutions-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
      gap: 24px;
      margin-top: 48px;
    }
    .expert-card {
      position: relative;
      padding: 40px;
      border-radius: var(--avab-radius);
      overflow: hidden;
      color: #fff;
      display: flex;
      flex-direction: column;
      justify-content: flex-end;
      min-height: 340px;
      transition: var(--transition-smooth);
      box-shadow: var(--avab-shadow-sm);
    }
    .expert-card::before {
      content: "";
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(40,46,42,0.9) 0%, rgba(40,46,42,0.2) 100%);
      z-index: 1;
      transition: var(--transition-smooth);
    }
    .expert-card img {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      object-fit: cover;
      z-index: 0;
      transition: transform 0.6s ease;
    }
    .expert-card:hover img { transform: scale(1.05); }
    .expert-card:hover::before {
      background: linear-gradient(to top, rgba(40,46,42,0.95) 0%, rgba(143,192,37,0.4) 100%);
    }
    .expert-content { position: relative; z-index: 2; display: flex; flex-direction: column; }
    .expert-content h3 {
      color: #fff;
      margin-bottom: 10px;
      font-size: 1.5rem;
      line-height: 1.2;
      min-height: 3.6rem;
      display: flex;
      align-items: flex-end;
    }
    .expert-content p {
      color: rgba(255,255,255,0.88);
      font-size: 1.02rem;
      margin-bottom: 0;
      min-height: 4.8rem;
    }

    /* ---- Länkpiller (miljöer) ---- */
    .link-pills { display: flex; flex-wrap: wrap; gap: 16px; margin-top: 32px; }
    .link-pills a {
      display: inline-flex;
      align-items: center;
      background: var(--avab-white);
      color: var(--avab-dark);
      border: 1px solid var(--avab-border);
      font-weight: 700;
      padding: 14px 24px;
      border-radius: 999px;
      font-size: 1.05rem;
      transition: var(--transition-smooth);
      box-shadow: var(--avab-shadow-sm);
    }
    .link-pills a:hover {
      background: var(--avab-green);
      border-color: var(--avab-green);
      transform: translateY(-2px);
      box-shadow: 0 8px 16px rgba(143,192,37,0.2);
    }

    /* ---- Synergi (icke-numrerade kort, staplade i aside) ---- */
    .flow-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 16px;
      margin-top: auto;
      padding-top: 32px;
      grid-auto-rows: 1fr;
    }

    /* ---- BYOD-banner ---- */
    .byod-banner {
      background: var(--avab-dark);
      color: #fff;
      border-radius: var(--avab-radius);
      padding: 40px;
      display: grid;
      grid-template-columns: 1.2fr 1fr;
      gap: 40px;
      align-items: center;
      border-left: 8px solid var(--avab-green);
      box-shadow: var(--avab-shadow-lg);
    }
    .byod-banner h2 { color: #fff; font-size: 2.2rem; }
    .byod-banner p { color: rgba(255,255,255,0.82); font-size: 1.1rem; }
    .byod-price { margin: 24px 0; }
    .byod-price strong { display: block; font-size: 2.5rem; font-weight: 800; color: var(--avab-green); line-height: 1; }
    .byod-price span { font-size: 0.9rem; color: rgba(255,255,255,0.55); }

    /* ---- Cirkulär AV ---- */
    .cirkular-card {
      padding: 48px;
      border-left: 8px solid var(--avab-green);
      background: var(--avab-white);
      box-shadow: var(--avab-shadow-sm);
      border-radius: var(--avab-radius-sm);
    }
    .cirkular-card .grid-2 { gap: 48px; align-items: center; }

    /* ---- Projektering: notiser + åtgärdskort ---- */
    .notice-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 32px; }
    .notice-item {
      padding: 20px;
      border-radius: var(--avab-radius-sm);
      background: var(--avab-white);
      border: 1px solid var(--avab-border);
      font-weight: 700;
      font-size: 1.05rem;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .notice-item::before { content: "✓"; color: var(--avab-green); font-size: 1.2rem; }

    .action-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 16px; }
    .action-card {
      background: var(--avab-light);
      border: 1px solid var(--avab-border);
      border-left: 4px solid var(--avab-green);
      padding: 24px;
      border-radius: var(--avab-radius-sm);
      display: flex;
      flex-direction: column;
      justify-content: center;
      color: var(--avab-dark);
      transition: var(--transition-smooth);
    }
    .action-card:hover {
      background: var(--avab-white);
      border-color: var(--avab-green);
      transform: translateY(-4px);
      box-shadow: var(--avab-shadow-sm);
    }
    .action-card strong { display: block; margin-bottom: 4px; }
    .action-card span { color: var(--avab-dark-muted); }

    /* ---- Kunskapsbank-lista ---- */
    .k-list { display: flex; flex-direction: column; gap: 16px; margin-top: 24px; }
    .k-item {
      background: #fff;
      padding: 24px;
      border-radius: var(--avab-radius-sm);
      border: 1px solid var(--avab-border);
      display: flex;
      justify-content: space-between;
      align-items: center;
      color: var(--avab-dark);
      transition: var(--transition-smooth);
      box-shadow: var(--avab-shadow-sm);
    }
    .k-item:hover { transform: translateX(6px); border-color: var(--avab-green); box-shadow: var(--avab-shadow-lg); }
    .k-item strong { font-size: 1.15rem; display: block; margin-bottom: 4px; }
    .k-item span {
      color: var(--avab-dark);
      font-weight: 800;
      font-size: 0.9rem;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      flex: 0 0 auto;
      margin-left: 20px;
    }
    .k-item span::after {
      content: "→";
      margin-left: 8px;
      font-size: 1.2rem;
      color: var(--avab-green);
      transition: transform 0.3s ease;
    }
    .k-item:hover span::after { transform: translateX(4px); }

    /* ---- Responsivt (sidspecifikt) ---- */
    @media (max-width: 1024px) {
      .byod-banner { grid-template-columns: 1fr; gap: 40px; }
      .expert-card { min-height: 320px; }
      .expert-content h3, .expert-content p { min-height: auto; }
      .cirkular-card { padding: 32px; }
    }
    @media (max-width: 768px) {
      .notice-grid, .action-grid { grid-template-columns: 1fr; }
      .byod-banner { padding: 32px 24px; }
      .k-item { flex-direction: column; align-items: flex-start; gap: 12px; }

      #losningar .solutions-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 12px; margin-top: 24px; }
      #losningar .expert-card { min-height: 92px; padding: 14px; border-radius: 16px; align-items: flex-end; }
      #losningar .expert-card::before { background: linear-gradient(to top, rgba(40,46,42,0.88) 0%, rgba(40,46,42,0.45) 100%); }
      #losningar .expert-card img { transform: none; }
      #losningar .expert-content { display: block; width: 100%; }
      #losningar .expert-content p { display: none; }
      #losningar .expert-content h3 { margin: 0; min-height: auto; font-size: 0.98rem; line-height: 1.15; font-weight: 800; display: block; }
    }
  </style>
</head>
<body>
