  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebPage",
    "@id": "https://www.avab.eu/#webpage",
    "url": "https://www.avab.eu/",
    "name": "AV-teknik, konferensrum, ljud, bild, säkerhet & projektering | AVAB",
    "description": "AVAB projekterar, installerar och integrerar AV-teknik, konferensrum, ljud, bild, säkerhet och kommunikation för publika miljöer i hela Sverige.",
    "inLanguage": "sv-SE",
    "isPartOf": { "@id": "https://www.avab.eu/#website" },
    "about": { "@id": "https://www.avab.eu/" },
    "datePublished": "2024-01-01",
    "dateModified": "2026-06-17",
