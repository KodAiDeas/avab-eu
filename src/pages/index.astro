  <section class="hero" style={`--hero-image:url('${heroImage}');`}>
    <div class="avab-container">
      <div class="hero-inner animate-in">
        <div class="eyebrow">Helhetslösningar för AV-teknik</div>

        <h1>AV-teknik – ljud, bild och säkerhet för publika miljöer</h1>

        <p class="lead">
          En riktigt bra teknisk lösning märks knappt. Den bara fungerar – i konferensrum, skolor, sporthallar, hotell och andra publika miljöer där ljud, bild och säkerhet måste samspela.
        </p>

        <div class="hero-bottom">
          <div class="hero-actions">
            <a class="button button-primary" href="/kontakt/">Boka kostnadsfri rådgivning</a>
            <a class="button button-secondary" href="#referenser">Se våra referensprojekt</a>
          </div>

          <div class="hero-pills">
            <a href="/projektering/">Projektering</a>
            <a href="/skola/">Skola</a>
            <a href="/kameraovervakning/">Kameraövervakning</a>
            <a href="/rastsignal/">Rastsignalsystem</a>
            <a href="/konferensteknik/">Konferensteknik</a>
          </div>
        </div>
      </div>
