---
import avabFooterLogo from "../assets/AVAB_logotyp_neg_green-white.png";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="avab-container footer-inner">
    <div class="footer-grid">
      <div class="footer-brand">
        <a class="footer-wordmark" href="/" aria-label="AVAB - till startsidan">
          <img src={avabFooterLogo.src} alt="AVAB" width="154" height="43" />
        </a>
        <p class="footer-tagline">
          Ljud, bild och säkerhet för offentliga miljöer - från projektering till
          driftsatt anläggning. Sedan mer än 35 år.
        </p>
        <address class="footer-contact">
          <a href="tel:+46548202080" class="footer-contact-row">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.4 2.1L8.1 10a16 16 0 0 0 6 6l1.3-1.3a2 2 0 0 1 2.1-.4c.9.3 1.9.6 2.9.7a2 2 0 0 1 1.6 2z"></path>
            </svg>
            <span>054-820 20 80</span>
          </a>
          <a href="mailto:info@avab.eu" class="footer-contact-row">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <rect x="2" y="4" width="20" height="16" rx="2"></rect>
              <path d="m22 7-10 6L2 7"></path>
            </svg>
            <span>info@avab.eu</span>
          </a>
          <span class="footer-contact-row">
            <svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
              <path d="M20 10c0 6-8 12-8 12S4 16 4 10a8 8 0 0 1 16 0z"></path>
              <circle cx="12" cy="10" r="3"></circle>
            </svg>
            <span>Skraggevägen 4, 663 41 Hammarö</span>
          </span>
        </address>
      </div>

      <nav class="footer-col" aria-label="Miljöer">
        <h2 class="footer-heading">Miljöer</h2>
        <ul class="footer-list footer-list--two-col">
          <li><a href="/miljo/sporthall/">Sporthall</a></li>
          <li><a href="/miljo/simhall/">Simhall</a></li>
          <li><a href="/miljo/ishall/">Ishall</a></li>
          <li><a href="/miljo/utomhusidrott/">Utomhusidrott</a></li>
          <li><a href="/miljo/kontor-konferens/">Kontor &amp; konferens</a></li>
          <li><a href="/miljo/hotell/">Hotell</a></li>
          <li><a href="/miljo/restaurang-bar-klubb/">Restaurang &amp; bar</a></li>
          <li><a href="/miljo/butik-retail/">Butik &amp; retail</a></li>
          <li><a href="/miljo/kopcentrum-galleria/">Köpcentrum</a></li>
          <li><a href="/miljo/skola/">Skola</a></li>
          <li><a href="/miljo/vard/">Vård</a></li>
          <li><a href="/miljo/industri/">Industri</a></li>
          <li><a href="/miljo/kyrka/">Kyrka</a></li>
          <li><a href="/miljo/parkering-garage/">Parkering &amp; garage</a></li>
        </ul>
      </nav>

      <nav class="footer-col" aria-label="Tjänster">
        <h2 class="footer-heading">Tjänster</h2>
        <ul class="footer-list">
          <li><a href="/tjanster/horslinga/">Hörslinga</a></li>
          <li><a href="/tjanster/kameraovervakning/">Kameraövervakning</a></li>
          <li><a href="/tjanster/taluppfattbarhet/">Taluppfattbarhet</a></li>
          <li><a href="/rastsignal/">Rastsignal</a></li>
        </ul>

        <h2 class="footer-heading footer-heading--spaced">Referenser</h2>
        <ul class="footer-list">
          <li><a href="/referenser/saffle-simhall/">Säffle simhall</a></li>
        </ul>
      </nav>

      <nav class="footer-col" aria-label="Genvägar">
        <h2 class="footer-heading">Genvägar</h2>
        <ul class="footer-list">
          <li><a href="/#losningar">Lösningar</a></li>
          <li><a href="/#miljoer">Miljöer</a></li>
          <li><a href="/#referenser">Referensprojekt</a></li>
          <li><a href="/#projektering">Projektering</a></li>
          <li><a href="/#faq-kunskap">Kunskapsbank</a></li>
        </ul>
      </nav>
    </div>

    <div class="footer-bottom">
      <p>© {year} AVAB. Alla rättigheter förbehållna.</p>
      <p>Org.nr 556977-1776</p>
    </div>
  </div>
</footer>
