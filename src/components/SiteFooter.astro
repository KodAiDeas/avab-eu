---
import avabFooterLogo from "../assets/AVAB_logotyp_neg_green-white.png";

const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="foot-cta">
    <div class="avab-container foot-cta-inner">
      <div class="foot-cta-text">
        <h2>Ska ni bygga en ny anläggning eller uppgradera ljudet?</h2>
        <p>Vi hjälper kommuner, byggbolag och elektriker - från ritning till driftsättning.</p>
      </div>
      <div class="foot-cta-actions">
        <a class="foot-btn foot-btn-primary" href="/kontakt/">Kontakta oss</a>
        <a class="foot-btn foot-btn-ghost" href="tel:+46548202080">
          <svg width="17" height="17" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          Ring 054-8202080
        </a>
      </div>
    </div>
  </div>

  <div class="avab-container foot-main">
    <div class="foot-col foot-brand">
      <a class="foot-brand-mark" href="/" aria-label="AVAB - till startsidan">
        <img src={avabFooterLogo.src} alt="AVAB" width="154" height="43" loading="lazy" decoding="async" />
      </a>
      <p class="foot-brand-desc">
        Ljud, bild och säkerhet för offentliga miljöer - från projektering till driftsatt anläggning. Sedan mer än 35 år.
      </p>
      <div class="foot-social">
        <a href="https://se.linkedin.com/company/avabsverige" aria-label="AVAB på LinkedIn" rel="noopener" target="_blank">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.13 1.45-2.13 2.94v5.67H9.35V9h3.42v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.07 2.07 0 1 1 0-4.14 2.07 2.07 0 0 1 0 4.14zM7.12 20.45H3.55V9h3.57v11.45zM22.22 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.45c.98 0 1.78-.77 1.78-1.72V1.72C24 .77 23.2 0 22.22 0z"/></svg>
        </a>
        <a href="https://www.facebook.com/avabsverige" aria-label="AVAB på Facebook" rel="noopener" target="_blank">
          <svg width="19" height="19" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M24 12.07C24 5.4 18.63 0 12 0S0 5.4 0 12.07C0 18.1 4.39 23.1 10.13 24v-8.44H7.08v-3.49h3.05V9.41c0-3.02 1.79-4.69 4.53-4.69 1.31 0 2.68.24 2.68.24v2.97h-1.51c-1.49 0-1.96.93-1.96 1.89v2.25h3.33l-.53 3.49h-2.8V24C19.61 23.1 24 18.1 24 12.07z"/></svg>
        </a>
      </div>
    </div>

    <div class="foot-col">
      <h4 class="foot-heading">Kontakt</h4>
      <a class="foot-contact-row" href="https://maps.google.com/?q=Skraggev%C3%A4gen+4,+663+41+Hammar%C3%B6" rel="noopener" target="_blank">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        <span><strong>AVAB</strong>Skraggevägen 4<br />663 41 Hammarö</span>
      </a>
      <a class="foot-contact-row" href="tel:+46548202080">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.9.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        <span><strong>054-820 20 80</strong>Vardagar 08-17</span>
      </a>
      <a class="foot-contact-row" href="mailto:info@avab.eu">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 5L2 7"/></svg>
        <span><strong>info@avab.eu</strong></span>
      </a>
    </div>

    <nav class="foot-col" aria-label="Genvägar i sidfot">
      <h4 class="foot-heading">Genvägar</h4>
      <ul class="foot-links">
        <li><a href="/#miljoer"><span class="foot-dot" aria-hidden="true"></span>Miljöer</a></li>
        <li><a href="/#losningar"><span class="foot-dot" aria-hidden="true"></span>Lösningar</a></li>
        <li><a href="/miljo/gym/"><span class="foot-dot" aria-hidden="true"></span>Gym</a></li>
        <li><a href="/rastsignal/"><span class="foot-dot" aria-hidden="true"></span>Rastsignal</a></li>
        <li><a href="/kontakt/"><span class="foot-dot" aria-hidden="true"></span>Kontakt</a></li>
      </ul>
    </nav>

    <div class="foot-col">
      <h4 class="foot-heading">Utvalda projekt</h4>
      <ul class="foot-links foot-links-muted">
        <li><a href="/referenser/saffle-simhall/">Säffle simhall</a></li>
        <li><a href="/referenser/sorby-sporthall-kumla/">Sörby sporthall, Kumla</a></li>
        <li><a href="/referenser/nordic-wellness-orebro-marieberg/">Nordic Wellness Örebro Marieberg</a></li>
        <li><a href="/referenser/ekhagsskolan-dals-langed/">Ekhagsskolan, Dals Långed</a></li>
        <li><a href="/referenser/hundfjallshotellet-hundfjallscenter-salen/">Hundfjällshotellet, Sälen</a></li>
      </ul>
    </div>
  </div>

  <div class="foot-bottom">
    <div class="avab-container foot-bottom-inner">
      <span>© {year} AVAB. Alla rättigheter förbehållna.</span>
      <span>Org.nr 556977-1776 <a href="/integritetspolicy/">Integritetspolicy</a></span>
    </div>
  </div>
</footer>

<style>
  .site-footer {
    --footer-bg: var(--avab-dark, #282E29);
    --footer-bg-deep: #1E231F;
    --footer-text: #F4F6F2;
    --footer-muted: #A7AEA4;
    --footer-accent: var(--avab-green, #8FC025);
    --footer-border: rgba(244, 246, 242, 0.1);

    background: var(--footer-bg);
    color: var(--footer-text);
    font-family: 'Plus Jakarta Sans', sans-serif;
  }

  .site-footer a {
    text-decoration: none;
  }

  .site-footer a:focus-visible {
    outline: var(--avab-focus, 3px solid var(--footer-accent));
    outline-offset: 3px;
  }

  .foot-cta {
    background: linear-gradient(90deg, rgba(143, 191, 135, 0.1), rgba(143, 191, 135, 0));
    border-bottom: 1px solid var(--footer-border);
  }

  .foot-cta-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 32px;
    padding-top: 40px;
    padding-bottom: 40px;
  }

  .foot-cta-text h2 {
    font-size: 1.6rem;
    font-weight: 700;
    letter-spacing: 0;
    margin: 0;
    color: var(--footer-text);
  }

  .foot-cta-text p {
    color: var(--footer-muted);
    font-size: 0.95rem;
    margin: 6px 0 0;
  }

  .foot-cta-actions {
    display: flex;
    gap: 14px;
    flex-shrink: 0;
  }

  .foot-btn {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    padding: 14px 26px;
    border-radius: 999px;
    font-size: 0.95rem;
    font-weight: 600;
    white-space: nowrap;
    transition: var(--transition-smooth, all 0.25s ease);
  }

  .foot-btn-primary {
    background: var(--footer-text);
    color: var(--footer-bg);
  }

  .foot-btn-primary:hover {
    background: #fff;
  }

  .foot-btn-ghost {
    border: 1px solid var(--footer-border);
    color: var(--footer-text);
  }

  .foot-btn-ghost:hover {
    border-color: var(--footer-accent);
    color: var(--footer-accent);
  }

  .foot-main {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1.3fr;
    gap: 56px;
    padding-top: 64px;
    padding-bottom: 56px;
  }

  .foot-heading {
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--footer-accent);
    font-weight: 700;
    margin: 0 0 22px;
  }

  .foot-brand-mark {
    display: inline-flex;
    align-items: center;
    margin-bottom: 16px;
  }

  .foot-brand-mark img {
    width: auto;
    height: 43px;
    object-fit: contain;
  }

  .foot-brand-desc {
    color: var(--footer-muted);
    font-size: 0.95rem;
    line-height: 1.6;
    max-width: 290px;
    margin: 0;
  }

  .foot-social {
    display: flex;
    gap: 12px;
    margin-top: 26px;
  }

  .foot-social a {
    width: 42px;
    height: 42px;
    border-radius: 12px;
    border: 1px solid var(--footer-border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--footer-text);
    transition: var(--transition-smooth, all 0.25s ease);
  }

  .foot-social a:hover {
    border-color: var(--footer-accent);
    color: var(--footer-accent);
  }

  .foot-contact-row {
    display: flex;
    gap: 13px;
    align-items: flex-start;
    margin-bottom: 18px;
    color: var(--footer-text);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  .foot-contact-row svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--footer-accent);
  }

  .foot-contact-row span {
    color: var(--footer-muted);
  }

  .foot-contact-row strong {
    display: block;
    font-weight: 600;
    color: var(--footer-text);
  }

  .foot-contact-row:hover strong {
    color: var(--footer-accent);
  }

  .foot-links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin: 0;
    padding: 0;
  }

  .foot-links a {
    color: var(--footer-text);
    font-size: 0.95rem;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 9px;
    transition: var(--transition-smooth, color 0.25s ease);
  }

  .foot-links a:hover {
    color: var(--footer-accent);
  }

  .foot-dot {
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--footer-accent);
    opacity: 0.7;
    flex-shrink: 0;
  }

  .foot-links-muted a {
    color: var(--footer-muted);
    font-weight: 400;
  }

  .foot-links-muted a:hover {
    color: var(--footer-text);
  }

  .foot-bottom {
    background: var(--footer-bg-deep);
    border-top: 1px solid var(--footer-border);
  }

  .foot-bottom-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
    padding-top: 24px;
    padding-bottom: 24px;
    color: var(--footer-muted);
    font-size: 0.85rem;
  }

  .foot-bottom-inner a {
    color: inherit;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .foot-bottom-inner a:hover,
  .foot-bottom-inner a:focus-visible {
    color: var(--footer-text);
  }

  @media (max-width: 1024px) {
    .foot-main {
      grid-template-columns: 1fr 1fr;
      gap: 48px 40px;
    }
  }

  @media (max-width: 768px) {
    .foot-cta-inner {
      flex-direction: column;
      align-items: flex-start;
      padding-top: 32px;
      padding-bottom: 32px;
    }

    .foot-cta-text h2 {
      font-size: 1.3rem;
    }

    .foot-cta-actions {
      width: 100%;
      flex-direction: column;
    }

    .foot-btn {
      justify-content: center;
      width: 100%;
    }

    .foot-main {
      grid-template-columns: 1fr;
      gap: 40px;
      padding-top: 48px;
      padding-bottom: 40px;
    }

    .foot-brand-desc {
      max-width: none;
    }

    .foot-bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
    }
  }
</style>
