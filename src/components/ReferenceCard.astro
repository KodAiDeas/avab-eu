---
// Ett helt klickbart referenskort för översikten på /referenser/.
// data-attributen används av filtreringen på sidan.
import type { Reference, FilterOption } from "../data/referenser";

interface Props {
  reference: Reference;
  environments: FilterOption[];
  technologies: FilterOption[];
}

const { reference, environments, technologies } = Astro.props;

const envLabels = reference.environments
  .map((id) => environments.find((e) => e.id === id)?.label)
  .filter(Boolean) as string[];

const techLabels = reference.technologies
  .map((id) => technologies.find((t) => t.id === id)?.label)
  .filter(Boolean) as string[];

// Visa som mest fyra teknikpiller på kortet, resten sammanfattas.
const shownTech = techLabels.slice(0, 4);
const extraTech = techLabels.length - shownTech.length;
---

<a
  class="ref-card ref-filter-card"
  href={reference.slug}
  data-environments={reference.environments.join(" ")}
  data-technologies={reference.technologies.join(" ")}
  data-title={reference.title.toLowerCase()}
  data-location={reference.location.toLowerCase()}
  data-excerpt={reference.excerpt.toLowerCase()}
  data-featured={reference.featured ? "true" : "false"}
>
  <img
    src={reference.image}
    alt={reference.imageAlt}
    width="900"
    height="600"
    loading="lazy"
    decoding="async"
  />
  <div class="ref-content">
    <span class="ref-meta">{envLabels[0]}{reference.location ? ` · ${reference.location}` : ""}</span>
    <h3>{reference.title}</h3>
    <p>{reference.excerpt}</p>
    {shownTech.length > 0 && (
      <ul class="ref-pills" aria-label="Teknik i projektet">
        {shownTech.map((label) => <li>{label}</li>)}
        {extraTech > 0 && <li class="ref-pill-more">+{extraTech}</li>}
      </ul>
    )}
    <span class="ref-cta">Läs referensen</span>
  </div>
</a>
